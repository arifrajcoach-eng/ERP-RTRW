rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Default Deny (First) ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'arifrajcoach@gmail.com' || 
        request.auth.uid == 'eHFrJ7Re1sb4xhMWlsHNoKr5qs53' ||
        request.auth.uid == 'MKe94buSU4SMg8jiRbCcOLwJp9H3' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    
    function isTenantMember(tenantId) {
      let userData = getUserData();
      return isSignedIn() && (
        isAdmin() || 
        (userData != null && (
          userData.tenantId == tenantId || 
          (userData.tenantId == 'RW_BERJUANG' && tenantId == 'trihprw26')
        ))
      );
    }
    
    function isPengurus() {
      let userData = getUserData();
      return isSignedIn() && (
        isAdmin() || 
        (userData != null && (userData.role in ['ADMIN', 'SUPER_ADMIN', 'RT', 'RW', 'BENDAHARA', 'SEKRETARIS']))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collection Rules ---

    match /tenants/{tenantId} {
      allow read: if isSignedIn();
      // Allow registration: Anyone can create a trial tenant if it doesn't exist
      allow create: if !exists(/databases/$(database)/documents/tenants/$(tenantId)) && 
                      request.resource.data.status in ['BASIC', 'TRIAL', 'Active'];
      allow update, delete: if isAdmin() || (isPengurus() && isTenantMember(tenantId));
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isPengurus() || isAdmin();
      // Allow pre-registration: Anyone can create a user if the ID (pre-reg) is unique
      allow create: if !exists(/databases/$(database)/documents/users/$(userId)) && 
                      (userId.startsWith('PRE_') || (isSignedIn() && request.auth.uid == userId));
      allow update: if isAdmin() || 
                      (isPengurus() && isTenantMember(resource.data.tenantId)) || 
                      (isSignedIn() && request.auth.uid == userId && 
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isSuperAdmin', 'tenantId']));
      allow delete: if isAdmin() || (isPengurus() && isTenantMember(resource.data.tenantId));
    }

    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus() && isTenantMember(docId);
    }
    
    match /buku_tamu/{docId} {
      allow list: if isTenantMember(resource.data.tenantId);
      allow get: if isSignedIn();
      allow create: if true; // Public guestbook
      allow update, delete: if isTenantMember(resource.data.tenantId);
    }

    match /kas/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isTenantMember(request.resource.data.tenantId);
    }

    match /data_warga/{docId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn();
      allow write: if isTenantMember(request.resource.data.tenantId);
    }

    match /surat/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || request.auth.uid == resource.data.authUid);
      allow create: if isSignedIn();
      allow update, delete: if isPengurus() && isTenantMember(resource.data.tenantId);
    }

    match /iuran/{docId} {
      allow read: if isTenantMember(resource.data.tenantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /emergencies/{docId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn();
      allow write: if isTenantMember(request.resource.data.tenantId);
    }

    match /verifikasi_warga/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

    match /chat_messages/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

    match /toko_products/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isPengurus() && isTenantMember(request.resource.data.tenantId);
    }

    match /toko_orders/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

  }
}
