rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return isSignedIn() 
        ? (exists(/databases/$(database)/documents/users/$(request.auth.uid))
           ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
           : (exists(/databases/$(database)/documents/data_warga/$(request.auth.uid))
              ? get(/databases/$(database)/documents/data_warga/$(request.auth.uid)).data
              : ('email' in request.auth.token
                 ? (exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower()))
                    ? get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data
                    : (exists(/databases/$(database)/documents/users/$(request.auth.token.email))
                       ? get(/databases/$(database)/documents/users/$(request.auth.token.email)).data
                       : (exists(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lower()))
                          ? get(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lower())).data
                          : null)))
                 : null)))
        : null;
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.uid == '85WvBMwEqOZ7VMkVnJIyQ8yRLDi1' ||
        ('email' in request.auth.token && request.auth.token.email.lower() == 'arifrajcoach@gmail.com') || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && (
        isAdmin() ||
        (tenantId != null && getUserData() != null && getUserData().get('tenantId', null) != null && (
          (getUserData().get('tenantId', '') is string && (
            getUserData().get('tenantId', '').lower() == tenantId.lower() || 
            getUserData().get('tenantId', '') == 'MASTER' || 
            (getUserData().get('tenantId', '').lower() == 'rw26_berjuang' && tenantId.lower().matches('.*berjuang.*')) ||
            (getUserData().get('tenantId', '').lower() == 'trihprw26' && tenantId.lower().matches('.*trih.*')) ||
            getUserData().get('tenantId', '').lower().matches('.*' + tenantId.lower() + '.*') ||
            tenantId.lower().matches('.*' + getUserData().get('tenantId', '').lower() + '.*') ||
            (getUserData().get('tenantId', '').lower().matches('.*rt.*') && (tenantId.lower().matches('.*rw26.*') || tenantId.lower().matches('.*berjuang.*') || tenantId.lower().matches('.*trih.*'))) ||
            (getUserData().get('tenantId', '').lower().matches('.*rw.*') && (tenantId.lower().matches('.*rw26.*') || tenantId.lower().matches('.*berjuang.*') || tenantId.lower().matches('.*trih.*') || tenantId.lower().matches('.*rt.*'))) ||
            
            // Direct, flexible RT to RT match fallback
            ((getUserData().get('tenantId', '').lower().matches('.*rt0?1.*') && tenantId.lower().matches('.*rt0?1.*')) ||
             (getUserData().get('tenantId', '').lower().matches('.*rt0?2.*') && tenantId.lower().matches('.*rt0?2.*')) ||
             (getUserData().get('tenantId', '').lower().matches('.*rt0?3.*') && tenantId.lower().matches('.*rt0?3.*')) ||
             (getUserData().get('tenantId', '').lower().matches('.*rt0?4.*') && tenantId.lower().matches('.*rt0?4.*')) ||
             (getUserData().get('tenantId', '').lower().matches('.*rt0?5.*') && tenantId.lower().matches('.*rt0?5.*')) ||
             (getUserData().get('tenantId', '').lower().matches('.*rt0?6.*') && tenantId.lower().matches('.*rt0?6.*')) ||
             (getUserData().get('tenantId', '').lower().matches('.*rt0?7.*') && tenantId.lower().matches('.*rt0?7.*')) ||
             (getUserData().get('tenantId', '').lower().matches('.*rt0?8.*') && tenantId.lower().matches('.*rt0?8.*')) ||
             (getUserData().get('tenantId', '').lower().matches('.*rt0?9.*') && tenantId.lower().matches('.*rt0?9.*')) ||
             (getUserData().get('tenantId', '').lower().matches('.*rt0?10.*') && tenantId.lower().matches('.*rt0?10.*')))
          )) ||
          (getUserData().get('tenantId', []) is list && (
            tenantId in getUserData().get('tenantId', []) ||
            tenantId.lower() in getUserData().get('tenantId', []) ||
            getUserData().get('tenantId', []).hasAny([tenantId, tenantId.lower(), 'MASTER', 'master'])
          ))
        )) ||
        (tenantId != null && 'email' in request.auth.token && request.auth.token.email.lower() == tenantId.lower() + "@gmail.com") ||
        (tenantId != null && 'email' in request.auth.token && (
            (request.auth.token.email.lower().matches('.*rt.*') && (tenantId.lower().matches('.*rw26.*') || tenantId.lower().matches('.*berjuang.*') || tenantId.lower().matches('.*trih.*'))) ||
            (request.auth.token.email.lower().matches('.*rt0?1.*') && tenantId.lower().matches('.*rt0?1.*')) ||
            (request.auth.token.email.lower().matches('.*rt0?2.*') && tenantId.lower().matches('.*rt0?2.*')) ||
            (request.auth.token.email.lower().matches('.*rt0?3.*') && tenantId.lower().matches('.*rt0?3.*')) ||
            (request.auth.token.email.lower().matches('.*rt0?4.*') && tenantId.lower().matches('.*rt0?4.*')) ||
            (request.auth.token.email.lower().matches('.*rt0?5.*') && tenantId.lower().matches('.*rt0?5.*')) ||
            (request.auth.token.email.lower().matches('.*rt0?6.*') && tenantId.lower().matches('.*rt0?6.*')) ||
            (request.auth.token.email.lower().matches('.*rt0?7.*') && tenantId.lower().matches('.*rt0?7.*')) ||
            (request.auth.token.email.lower().matches('.*rt0?8.*') && tenantId.lower().matches('.*rt0?8.*')) ||
            (request.auth.token.email.lower().matches('.*rt0?9.*') && tenantId.lower().matches('.*rt0?9.*')) ||
            (request.auth.token.email.lower().matches('.*rt10.*') && tenantId.lower().matches('.*rt10.*')) ||
            (request.auth.token.email.lower().matches('.*rw26.*') && (tenantId.lower().matches('.*rw26.*') || tenantId.lower().matches('.*berjuang.*') || tenantId.lower().matches('.*rt.*'))) ||
            (request.auth.token.email.lower().matches('.*rw.*') && (tenantId.lower().matches('.*rw.*') || tenantId.lower().matches('.*berjuang.*') || tenantId.lower().matches('.*trih.*') || tenantId.lower().matches('.*rt.*')))
        ))
      );
    }
    
    function isPengurus() {
      return isSignedIn() && (
        isAdmin() ||
        (getUserData() != null && (
          ('role' in getUserData() && getUserData().role in ['RT', 'RW', 'BENDAHARA', 'SEKRETARIS', 'KADER', 'KETUA RT', 'KETUA RW', 'PENGURUS', 'SUPER_ADMIN', 'ADMIN', 'rt', 'rw', 'bendahara', 'sekretaris', 'kader', 'ketua rt', 'ketua rw', 'pengurus', 'super_admin', 'admin']) ||
          ('role' in getUserData() && getUserData().role is string && getUserData().role.lower().matches('.*(rt|rw|bendahara|sekretaris|kader|admin|pengurus|super_admin).*')) ||
          ('tenantId' in getUserData() && (
            (getUserData().tenantId is string && getUserData().tenantId == 'MASTER') ||
            (getUserData().tenantId is list && 'MASTER' in getUserData().tenantId)
          ))
        )) ||
        ('email' in request.auth.token && (
          request.auth.token.email.lower().matches('.*rt.*') || 
          request.auth.token.email.lower().matches('.*rw.*') ||
          request.auth.token.email.lower().matches('.*admin.*')
        ))
      );
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        (resource != null && isTenantMember(resource.data.get('tenantId', 'MASTER'))) ||
        (resource == null)
      );
      allow list: if isSignedIn() && (
        isAdmin() || 
        isPengurus()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        (resource != null && isTenantMember(resource.data.get('tenantId', 'MASTER'))) ||
        (resource == null)
      );
      allow delete: if isAdmin() || (isSignedIn() && (
        request.auth.uid == userId || 
        ('email' in request.auth.token && (
          userId.lower() == request.auth.token.email.lower() || 
          userId.lower() == 'pre_' + request.auth.token.email.lower() ||
          (resource != null && resource.data.get('email', '').lower() == request.auth.token.email.lower())
        ))
      ));
    }

    match /tenants/{tenantId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isAdmin() || (isPengurus() && isTenantMember(tenantId));
    }

    match /data_warga/{nik} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        isPengurus() ||
        (resource != null && isTenantMember(resource.data.get('tenantId', 'MASTER'))) ||
        (resource != null && resource.data.email == request.auth.token.email)
      );
      allow write: if isSignedIn() && (
        isAdmin() ||
        isPengurus() ||
        ((resource == null || isTenantMember(resource.data.get('tenantId', 'MASTER'))) && 
         (request.resource == null || isTenantMember(request.resource.data.get('tenantId', 'MASTER'))))
      );
    }

    match /verifikasi_warga/{id} {
      allow read, create: if true;
      allow update: if isSignedIn() && (isPengurus() || isAdmin());
      allow delete: if isAdmin();
    }

    match /surat/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (!('rwTenantId' in request.resource.data) || (request.resource.data.rwTenantId is string && request.resource.data.rwTenantId != ""));
      allow update: if isAdmin() || (
        isSignedIn() && (
          resource.data.authUid == request.auth.uid || 
          resource.data.userId == request.auth.uid || 
          isPengurus()
        )
      );
      allow delete: if isAdmin() || (
        isSignedIn() && (
          resource.data.authUid == request.auth.uid || 
          resource.data.userId == request.auth.uid || 
          (getUserData() != null && 'nik' in getUserData() && resource.data.nik == getUserData().nik) ||
          isPengurus()
        )
      );
    }

    match /kas/{id} {
      allow read: if true;
      allow create, update: if isPengurus() || isTenantMember(request.resource.data.get('tenantId', 'MASTER'));
      allow delete: if isPengurus() && isTenantMember(resource.data.get('tenantId', 'MASTER'));
    }

    match /kas_summary/{tenantId} {
      allow read: if true;
      allow create, update: if isPengurus() && isTenantMember(tenantId);
    }

    match /iuran/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if (isPengurus() && isTenantMember(resource.data.get('tenantId', 'MASTER'))) || (
        isSignedIn() && resource != null && (
          resource.data.get('userId', '') == request.auth.uid ||
          resource.data.get('recordedBy', '') == request.auth.uid ||
          (getUserData() != null && 'nik' in getUserData() && resource.data.get('nik', '') == getUserData().nik) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('nik', '') == resource.data.get('nik', '')) ||
          (exists(/databases/$(database)/documents/data_warga/$(request.auth.uid)) && get(/databases/$(database)/documents/data_warga/$(request.auth.uid)).data.get('nik', '') == resource.data.get('nik', ''))
        )
      );
    }

    match /branding/{tenantId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /toko_products/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /chat_messages/{id} {
      allow read: if isSignedIn();
      allow create: if isTenantMember(request.resource.data.get('tenantId', 'MASTER'));
    }

    match /complaints/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if (isPengurus() && isTenantMember(resource.data.get('tenantId', 'MASTER'))) || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
    }

    match /emergencies/{id} {
      allow read, write: if isSignedIn();
    }

    match /emergency_logs/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.get('userId', '') == request.auth.uid;
      allow write: if isAdmin();
    }

    match /subscriptions/{tenantId} {
      allow read, write: if isSignedIn();
    }

    match /push_subscriptions/{subId} {
      allow read, write: if true;
    }

    match /mading/{id} {
      allow read: if true;
      allow write: if isPengurus();
    }
    
    match /buku_tamu/{id} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        (resource != null && isTenantMember(resource.data.get('tenantId', 'MASTER')))
      );
      allow list: if isSignedIn();
      allow create: if true;
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource != null && isTenantMember(resource.data.get('tenantId', 'MASTER'))) ||
        (request.resource != null && isTenantMember(request.resource.data.get('tenantId', 'MASTER')))
      );
      allow delete: if isAdmin() || (
        isSignedIn() && resource != null && isTenantMember(resource.data.get('tenantId', 'MASTER'))
      );
    }
    
    match /settings/{docId} {
      allow read, write: if true;
    }

    match /tenant_settings/{tenantId} {
      allow read, write: if isSignedIn();
    }

    // Catch-all
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
