rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Unified Tenant/Role Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        ("email" in request.auth.token && request.auth.token.email == 'arifrajcoach@gmail.com') || 
        request.auth.uid == 'eHFrJ7Re1sb4xhMWlsHNoKr5qs53' ||
        request.auth.uid == 'MKe94buSU4SMg8jiRbCcOLwJp9H3'
      ); 
    }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }
    
    function isTenantMember(tenantId) {
      let userData = getUserData();
      return isSignedIn() && (isAdmin() || (userData != null && userData.tenantId == tenantId));
    }
    
    function isPengurus() {
      let userData = getUserData();
      return isSignedIn() && (
        isAdmin() || 
        (userData != null && (userData.role in ['ADMIN', 'SUPER_ADMIN', 'RT', 'RW', 'BENDAHARA', 'SEKRETARIS']))
      );
    }

    // --- Specific collection rules ---
    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }
    
    match /tenant_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /buku_tamu/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
      allow create: if true;
    }

    match /tenant_registrations/{docId} {
      allow read, write: if true;
    }
    
    match /tenants/{docId} {
      allow read, write: if isAdmin();
    }

    match /inventaris/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_kategori/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_lokasi/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_supplier/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /iuran/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_tarik_saldo/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /posyandu_kegiatan/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /posbindu_kegiatan/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /pemeriksaan_balita/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }
    
    match /pemeriksaan_posbindu/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /emergencies/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow writing for SOS
    }

    match /inventaris_logs/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /imunisasi/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /ibu_hamil/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /kas/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_kategori/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /surat/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || request.auth.uid == resource.data.authUid);
      allow create: if isSignedIn();
      allow update, delete: if isPengurus() && isTenantMember(resource.data.tenantId);
    }


    match /public_usernames/{username} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isPengurus();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isSuperAdmin', 'tenantId']));
      allow delete: if isAdmin();
    }

    match /verifikasi_warga/{docId} {
      allow read, write: if true;
    }

    match /balita/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_setoran/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /warga/{docId} {
      allow read: if isSignedIn();
      allow write: if isTenantMember(request.resource.data.tenantId) || isTenantMember(resource.data.tenantId);
    }

    match /data_warga/{docId} {
      allow read: if isSignedIn();
      allow write: if isTenantMember(request.resource.data.tenantId) || isTenantMember(resource.data.tenantId);
    }

    match /voting_candidates/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /voting_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /voting_votes/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isPengurus();
      allow delete: if isPengurus();
    }

    match /toko_products/{allPaths=**} {
      allow read, write: if true;
    }
    match /toko_orders/{allPaths=**} {
      allow read, write: if true;
    }

    // Default deny (Must be last)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
