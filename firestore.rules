rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Unified Tenant/Role Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'arifrajcoach@gmail.com' || 
        request.auth.uid == 'eHFrJ7Re1sb4xhMWlsHNoKr5qs53' ||
        request.auth.uid == 'MKe94buSU4SMg8jiRbCcOLwJp9H3' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }
    
    function isTenantMember(tenantId) {
      let userData = getUserData();
      return isSignedIn() && (
        isAdmin() || 
        (userData != null && (
          userData.tenantId == tenantId || 
          (userData.tenantId == 'RW_BERJUANG' && tenantId == 'trihprw26')
        ))
      );
    }
    
    function isPengurus() {
      return isSignedIn() && (
        isAdmin() || 
        (getUserData() != null && (getUserData().role in ['ADMIN', 'SUPER_ADMIN', 'RT', 'RW', 'BENDAHARA', 'SEKRETARIS']))
      );
    }

    // --- Specific collection rules ---
    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus() && isTenantMember(docId);
    }
    
    match /tenant_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus() && isTenantMember(docId);
    }

    match /buku_tamu/{docId} {
      allow list: if isTenantMember(resource.data.tenantId);
      allow get: if isSignedIn();
      allow create: if true;
      allow update, delete: if isTenantMember(resource.data.tenantId);
    }

    match /tenant_registrations/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }
    
    match /tenants/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isPengurus() && isTenantMember(docId));
    }

    match /inventaris/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_kategori/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_lokasi/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_supplier/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /iuran/{docId} {
      allow read: if isTenantMember(resource.data.tenantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isTenantMember(resource.data.tenantId);
    }

    match /ppob_trx/{docId} {
      allow read: if isTenantMember(resource.data.tenantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_tarik_saldo/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /posyandu_kegiatan/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /posbindu_kegiatan/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /pemeriksaan_balita/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }
    
    match /pemeriksaan_posbindu/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /emergencies/{docId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn();
      allow write: if isTenantMember(request.resource.data.tenantId); // Allow writing for SOS, only for tenants
    }

    match /inventaris_logs/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /imunisasi/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /ibu_hamil/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /kas/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_kategori/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /surat/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || request.auth.uid == resource.data.authUid);
      allow create: if isSignedIn();
      allow update, delete: if isPengurus() && isTenantMember(resource.data.tenantId);
    }


    match /public_usernames/{username} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isPengurus() || isAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isPengurus());
      allow update: if isAdmin() || (isPengurus() && isTenantMember(resource.data.tenantId)) || (isSignedIn() && request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isSuperAdmin', 'tenantId']));
      allow delete: if isAdmin() || (isPengurus() && isTenantMember(resource.data.tenantId));
    }

    match /verifikasi_warga/{docId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn();
      allow write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

    match /bookings/{docId} {
      allow list: if isSignedIn() && (isTenantMember(resource.data.tenantId) || resource.data.userId == request.auth.uid);                
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isTenantMember(resource.data.tenantId) && isPengurus();
    }

    match /posyandu_balita/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

    match /balita/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /lansia/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

    match /warga_sakit/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

    match /sampah_setoran/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /warga/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isTenantMember(request.resource.data.tenantId) || isTenantMember(resource.data.tenantId);
    }

    match /data_warga/{docId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn();
      allow write: if isTenantMember(request.resource.data.tenantId) || isTenantMember(resource.data.tenantId);
    }

    match /voting_candidates/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /voting_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /voting_votes/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isPengurus();
      allow delete: if isPengurus();
    }

    match /toko_products/{docId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn();
      allow write: if isPengurus() && isTenantMember(request.resource.data.tenantId);
    }
    match /toko_products_seller/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isPengurus() && isTenantMember(request.resource.data.tenantId);
    }
    match /toko_orders/{docId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn();
      allow write: if isTenantMember(request.resource.data.tenantId);
    }

    match /chat_messages/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update, delete: if isTenantMember(resource.data.tenantId) && isPengurus();
    }

    match /complaints/{docId} {
      allow list: if isSignedIn() && (isTenantMember(resource.data.tenantId) || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isTenantMember(resource.data.tenantId) && isPengurus();
    }

    match /regions/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /audit_logs/{docId} {
      allow read: if isAdmin() || (isPengurus() && isTenantMember(resource.data.tenantId));
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantMember(resource.data.tenantId));
      allow write: if isTenantMember(resource.data.tenantId) && isPengurus();
    }

    match /usage_logs/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isAdmin();
    }

    match /ai_usage_logs/{docId} {
      allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /monthly_reports/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isAdmin();
    }

    match /ai_cache/{docId} {
      allow read, write: if isSignedIn();
    }

    // Default deny (Must be last)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
