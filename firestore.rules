rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function getTenantId() {
      let user = getUserData();
      return user != null ? user.get('tenantId', 'RW26_SMART') : 'RW26_SMART';
    }

    function isSameTenant(data) {
      return data.get('tenantId', 'RW26_SMART') == getTenantId();
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'arifrajcoach@gmail.com' || 
        (getUserData() != null && getUserData().get('isSuperAdmin', false) == true)
      );
    }

    function isAdmin() {
      let user = getUserData();
      return isSignedIn() && (
        isSuperAdmin() || 
        (user != null && (user.get('role', 'Viewer') == 'ADMIN' || user.get('role', 'Viewer') == 'RW'))
      );
    }

    function isOperator() {
      let user = getUserData();
      let role = user != null ? user.get('role', 'Viewer') : 'Viewer';
      return isSuperAdmin() || role == 'ADMIN' || role == 'RW' || role == 'RT' || role == 'BENDAHARA' || role == 'SEKRETARIS';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidWarga(data) {
      return data.nik is string && data.nik.size() >= 1 &&
             data.nama is string && data.nama.size() <= 100 &&
             data.tenantId is string && data.tenantId.size() <= 50;
    }

    function isValidKas(data) {
      return (data.get('debit', 0) is number || data.get('kredit', 0) is number) &&
             data.tipe in ['Masuk', 'Keluar'] &&
             data.tanggal is string &&
             data.tenantId is string;
    }

    function isValidSurat(data) {
      return data.id is string &&
             data.pemohon is string &&
             data.status in ['Diajukan', 'Draft', 'Terkirim', 'Selesai', 'Ditolak'] &&
             data.tenantId is string;
    }

    function isValidIuran(data) {
      return data.nominal is number &&
             data.status in ['Lunas', 'Pending'] &&
             data.nama is string &&
             data.tenantId is string;
    }

    // --- Tenants Collection ---
    match /tenants/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // --- Settings Collection ---
    match /settings/{tId} {
      allow read: if isSignedIn() && (isSuperAdmin() || tId == getTenantId());
      allow write: if isAdmin() && tId == getTenantId();
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || (resource != null && request.auth.token.email == resource.data.get('email', '')));
      allow create: if isSuperAdmin() || (isAdmin() && incoming().get('tenantId', '') == getTenantId());
      allow update: if isSuperAdmin() || (isAdmin() && existing().get('tenantId', '') == getTenantId()) || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isSuperAdmin() || (isAdmin() && existing().get('tenantId', '') == getTenantId());
    }

    // --- Warga Collection ---
    match /warga/{nik} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(nik) && isValidWarga(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidId(nik) && isValidWarga(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    // --- Kas Collection ---
    match /kas/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidKas(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidKas(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    // --- Surat Collection ---
    match /surat/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isSignedIn() && isValidId(id) && isValidSurat(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidSurat(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    // --- Iuran Collection ---
    match /iuran/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidIuran(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidIuran(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }
  }
}
