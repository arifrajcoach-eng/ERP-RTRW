rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function getRole() {
      let data = getUserData();
      return data != null ? data.get('role', 'Viewer') : 'Viewer';
    }

    function getTenantId() {
      let data = getUserData();
      return data != null ? data.get('tenantId', 'RW26_SMART') : 'RW26_SMART';
    }

    function isSameTenant(data) {
      return data.get('tenantId', 'RW26_SMART') == getTenantId();
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'arifrajcoach@gmail.com' || 
        (getUserData() != null && getUserData().get('isSuperAdmin', false) == true)
      );
    }

    function isAdmin() {
      return isSignedIn() && (isSuperAdmin() || getRole() == 'ADMIN' || getRole() == 'RW');
    }

    function isOperator() {
      let role = getRole();
      return isSignedIn() && (isSuperAdmin() || role == 'ADMIN' || role == 'RW' || role == 'RT' || role == 'BENDAHARA' || role == 'SEKRETARIS');
    }

    function isAnonymous() {
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' ||
        !exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }

    function isWargaOfRT(rt) {
      let data = getUserData();
      return data != null && data.get('rt', '') == rt;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidWarga(data) {
      return data.nik is string && data.nik.size() >= 1 &&
             data.nama is string && data.nama.size() <= 100 &&
             data.tenantId is string && data.tenantId.size() <= 60 &&
             data.kk is string &&
             data.rt is string &&
             data.rw is string &&
             (!('agama' in data) || data.agama is string);
    }

    function isValidKas(data) {
      return (data.get('debit', 0) is number || data.get('kredit', 0) is number) &&
             data.tipe in ['Masuk', 'Keluar'] &&
             data.tanggal is string &&
             data.tenantId is string;
    }

    function isValidSurat(data) {
      return data.id is string &&
             data.pemohon is string &&
             data.status in ['Diajukan', 'Draft', 'Terkirim', 'Selesai', 'Ditolak'] &&
             data.tenantId is string;
    }

    function isValidIuran(data) {
      return data.nominal is number &&
             data.status in ['Lunas', 'Pending'] &&
             data.nama is string &&
             data.tenantId is string;
    }

    function isValidInventaris(data) {
      return data.nama_barang is string &&
             data.kategori is string &&
             data.lokasi is string &&
             data.stok is number &&
             data.tenantId is string;
    }

    function isValidInventarisLog(data) {
      return data.itemId is string &&
             data.aktivitas is string &&
             data.tanggal is string &&
             data.tenantId is string;
    }

    function isValidKategori(data) {
      return data.nama_kategori is string && data.tenantId is string;
    }

    function isValidLokasi(data) {
      return data.nama_lokasi is string && data.tenantId is string;
    }

    function isValidSupplier(data) {
      return data.nama is string && data.tenantId is string;
    }

    function isValidBalita(data) {
      return data.nama is string && data.tglLahir is string && data.jk in ['Laki-Laki', 'Perempuan'] && data.orangTuaId is string && data.tenantId is string;
    }

    function isValidIbuHamil(data) {
      return data.nama is string && data.nik is string && data.tenantId is string;
    }

    function isValidPosyanduKegiatan(data) {
      return data.tanggal is string && data.lokasi is string && data.tenantId is string;
    }

    function isValidVerifikasi(data) {
      return (data.nik is string || data.nik is number) && 
             data.nama is string && 
             data.tenantId is string && 
             data.status in ["Belum Diverifikasi", "Menunggu Persetujuan", "Disetujui", "Ditolak"];
    }

    function isOwnerOfVerifikasi(data) {
      return isSignedIn() && data.get('userId', '') == request.auth.uid;
    }

    function isValidPemeriksaan(data) {
      return data.balitaId is string && data.tanggal is string && (data.beratBadan is number || data.tinggiBadan is number) && data.tenantId is string;
    }

    function isValidImunisasi(data) {
      return data.balitaId is string && data.jenisImunisasi is string && data.tanggal is string && data.tenantId is string;
    }

    function isValidSampahKategori(data) {
      return data.nama is string && data.satuan in ['kg', 'liter', 'pcs'] && data.hargaBeli is number && data.tenantId is string;
    }

    function isValidSampahSetoran(data) {
      return data.nasabahId is string && data.kategoriId is string && data.berat is number && data.total is number && data.tanggal is string && data.tenantId is string;
    }

    function isValidSampahTarik(data) {
      return data.nasabahId is string && data.nominal is number && data.tanggal is string && data.tenantId is string;
    }

    function isValidEmergency(data) {
      return data.userName is string && data.status in ['ACTIVE', 'RESOLVED'] && data.tenantId is string;
    }

    // --- Tenants Collection ---
    match /tenants/{tenantId} {
      allow list: if isSignedIn() && isSuperAdmin();
      allow get: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // --- Settings Collection ---
    match /settings/{tId} {
      allow get: if isSignedIn() && (isSuperAdmin() || tId == getTenantId());
      allow write: if isSignedIn() && (isSuperAdmin() || (isAdmin() && tId == getTenantId()));
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow list: if isSignedIn() && (isSuperAdmin() || (resource.data.tenantId == getTenantId() && isAdmin()));
      allow get: if isSignedIn() && (isSuperAdmin() || request.auth.uid == userId || isSameTenant(existing()));
      
      allow create: if isSignedIn() && (
        isSuperAdmin() || 
        (request.auth.uid == userId && incoming().get('role', 'RT') == 'RT') || 
        (isAdmin() && incoming().get('tenantId', '') == getTenantId())
      );
      allow update: if isSuperAdmin() || (isAdmin() && existing().get('tenantId', '') == getTenantId()) || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isSuperAdmin() || (isAdmin() && existing().get('tenantId', '') == getTenantId());
    }

    // --- Data Warga Collection ---
    match /data_warga/{nik} {
      allow list: if isSignedIn() && (isSuperAdmin() || (resource.data.tenantId == getTenantId() && (getRole() != 'RT' || resource.data.rt == getUserData().get('rt', ''))));
      allow get: if isSignedIn() && (isSuperAdmin() || (isSameTenant(existing()) && (getRole() != 'RT' || existing().get('rt', '') == getUserData().get('rt', ''))));
      
      allow create: if isSuperAdmin() || (isOperator() && isValidId(nik) && isValidWarga(incoming()) && isSameTenant(incoming()) && (getRole() != 'RT' || incoming().rt == getUserData().get('rt', '')));
      allow update: if isSuperAdmin() || (isOperator() && isValidId(nik) && isValidWarga(incoming()) && isSameTenant(existing()) && isSameTenant(incoming()) && (getRole() != 'RT' || (existing().rt == getUserData().get('rt', ''))));
      allow delete: if isAdmin() || isOperator();
    }

    // --- Verifikasi Warga Collection ---
    match /verifikasi_warga/{id} {
      allow list: if isSignedIn() && (
        isSuperAdmin() || 
        (isOperator() && resource.data.tenantId == getTenantId()) ||
        isOwnerOfVerifikasi(resource.data)
      );
      allow get: if isSignedIn() && (
        isSuperAdmin() || 
        (isSameTenant(existing()) && isOperator()) || 
        isOwnerOfVerifikasi(existing())
      );
      
      allow create: if isSignedIn() && isValidId(id) && isValidVerifikasi(incoming()) && 
                    incoming().userId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        (isOperator() && isSameTenant(existing()) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'catatan', 'updatedAt'])) || 
        (
          isOwnerOfVerifikasi(existing()) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['nama', 'nik', 'ktpUrl', 'kkUrl', 'updatedAt', 'agama', 'tempatLahir', 'tglLahir', 'jk', 'kk', 'alamat', 'rt', 'rw', 'profesi', 'pendidikanTerakhir', 'kawin', 'posisi', 'kewarganegaraan', 'userId', 'status', 'submittedAt', 'catatan', 'tenantId', 'id'])
        )
      );
      allow delete: if isAdmin();
    }

    // --- Kas Collection ---
    match /kas/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || (resource.data.tenantId == getTenantId() && (getRole() != 'RT' || resource.data.rt == getUserData().get('rt', ''))));
      allow get: if isSignedIn() && (isSuperAdmin() || (isSameTenant(existing()) && (getRole() != 'RT' || existing().get('rt', '') == getUserData().get('rt', ''))));
      
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidKas(incoming()) && isSameTenant(incoming()) && (isSuperAdmin() || getRole() != 'RT' || incoming().rt == getUserData().get('rt', ''));
      allow update: if isOperator() && isEmailVerified() && isValidKas(incoming()) && isSameTenant(existing()) && isSameTenant(incoming()) && (isSuperAdmin() || getRole() != 'RT' || (existing().rt == getUserData().get('rt', '') && incoming().rt == getUserData().get('rt', '')));
      allow delete: if isAdmin() && isEmailVerified();
    }

    // --- Surat Collection ---
    match /surat/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || (resource.data.tenantId == getTenantId() && (getRole() != 'RT' || resource.data.rt == getUserData().get('rt', ''))));
      allow get: if isSignedIn() && (isSuperAdmin() || (isSameTenant(existing()) && (getRole() != 'RT' || existing().get('rt', '') == getUserData().get('rt', ''))));
      
      allow create: if isSignedIn() && isValidId(id) && isValidSurat(incoming()) && isSameTenant(incoming()) && (isSuperAdmin() || getRole() != 'RT' || incoming().rt == getUserData().get('rt', ''));
      allow update: if isOperator() && isEmailVerified() && isValidSurat(incoming()) && isSameTenant(existing()) && isSameTenant(incoming()) && (isSuperAdmin() || getRole() != 'RT' || (existing().rt == getUserData().get('rt', '') && incoming().rt == getUserData().get('rt', '')));
      allow delete: if isAdmin() && isEmailVerified();
    }

    // --- Iuran Collection ---
    match /iuran/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || (resource.data.tenantId == getTenantId() && (getRole() != 'RT' || resource.data.rt == getUserData().get('rt', ''))));
      allow get: if isSignedIn() && (isSuperAdmin() || (isSameTenant(existing()) && (getRole() != 'RT' || existing().get('rt', '') == getUserData().get('rt', ''))));
      
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidIuran(incoming()) && isSameTenant(incoming()) && (isSuperAdmin() || getRole() != 'RT' || incoming().rt == getUserData().get('rt', ''));
      allow update: if isOperator() && isEmailVerified() && isValidIuran(incoming()) && isSameTenant(existing()) && isSameTenant(incoming()) && (isSuperAdmin() || getRole() != 'RT' || (existing().rt == getUserData().get('rt', '') && incoming().rt == getUserData().get('rt', '')));
      allow delete: if isAdmin() && isEmailVerified();
    }

    // --- Inventaris Collection ---
    match /inventaris/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      
      allow create: if (isSuperAdmin() || (isOperator() && isEmailVerified())) && isValidId(id) && isValidInventaris(incoming()) && isSameTenant(incoming());
      allow update: if (isSuperAdmin() || (isOperator() && isEmailVerified())) && isValidInventaris(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isSuperAdmin() || (isAdmin() && isEmailVerified());
    }

    // --- Inventaris Logs Collection ---
    match /inventaris_logs/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      
      allow create: if (isSuperAdmin() || (isOperator() && isEmailVerified())) && isValidId(id) && isValidInventarisLog(incoming()) && isSameTenant(incoming());
      allow update: if (isSuperAdmin() || (isOperator() && isEmailVerified())) && isValidInventarisLog(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isSuperAdmin() || (isAdmin() && isEmailVerified());
    }

    match /inventaris_kategori/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidKategori(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidKategori(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    match /inventaris_lokasi/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidLokasi(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidLokasi(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    match /inventaris_supplier/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidSupplier(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidSupplier(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    // --- Posyandu Collections ---
    match /balita/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidBalita(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidId(id) && isValidBalita(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    match /ibu_hamil/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidIbuHamil(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidId(id) && isValidIbuHamil(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    match /posyandu_kegiatan/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidPosyanduKegiatan(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidId(id) && isValidPosyanduKegiatan(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    match /pemeriksaan_balita/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidPemeriksaan(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidId(id) && isValidPemeriksaan(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    match /imunisasi/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidImunisasi(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidId(id) && isValidImunisasi(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    match /sampah_kategori/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidSampahKategori(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidId(id) && isValidSampahKategori(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    match /sampah_setoran/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidSampahSetoran(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidId(id) && isValidSampahSetoran(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    match /sampah_tarik_saldo/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isEmailVerified() && isValidId(id) && isValidSampahTarik(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isEmailVerified() && isValidId(id) && isValidSampahTarik(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    // --- Emergency Collections ---
    match /emergencies/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isSignedIn() && isValidId(id) && isValidEmergency(incoming()) && isSameTenant(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid)) && isValidEmergency(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin() && isEmailVerified();
    }

    // --- Branding and Template Collections ---
    match /tenant_settings/{tId} {
      allow get: if isSignedIn() && (isSuperAdmin() || tId == getTenantId());
      allow write: if isSignedIn() && (isSuperAdmin() || (isAdmin() && tId == getTenantId()));
    }

    match /kop_settings/{tId} {
      allow get: if isSignedIn() && (isSuperAdmin() || tId == getTenantId());
      allow write: if isSignedIn() && (isSuperAdmin() || (isAdmin() && tId == getTenantId()));
    }

    match /templates/{id} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.tenantId == getTenantId());
      allow get: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isSignedIn() && (isSuperAdmin() || (isAdmin() && isValidId(id) && isSameTenant(incoming())));
      allow update: if isSignedIn() && (isSuperAdmin() || (isAdmin() && isSameTenant(existing()) && isSameTenant(incoming())));
      allow delete: if isSuperAdmin() || isAdmin();
    }
  }
}
