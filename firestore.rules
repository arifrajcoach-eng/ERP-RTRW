rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return isSignedIn() 
        ? (exists(/databases/$(database)/documents/users/$(request.auth.uid))
           ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
           : (exists(/databases/$(database)/documents/data_warga/$(request.auth.uid))
              ? get(/databases/$(database)/documents/data_warga/$(request.auth.uid)).data
              : ('email' in request.auth.token
                 ? (exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower()))
                    ? get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data
                    : (exists(/databases/$(database)/documents/users/$(request.auth.token.email))
                       ? get(/databases/$(database)/documents/users/$(request.auth.token.email)).data
                       : (exists(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lower()))
                          ? get(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lower())).data
                          : null)))
                 : null)))
        : null;
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        ('email' in request.auth.token && (request.auth.token.email.lower() == 'arifrajcoach@gmail.com' || request.auth.token.email.lower() == 'arifrajmci@gmail.com')) || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && (
        isAdmin() ||
        (getUserData() != null && 'tenantId' in getUserData() && (
          getUserData().tenantId.lower() == tenantId.lower() || 
          getUserData().tenantId == 'MASTER' || 
          (getUserData().tenantId.lower() == 'rw26_berjuang' && tenantId.lower().matches('.*berjuang.*')) ||
          (getUserData().tenantId.lower() == 'trihprw26' && tenantId.lower().matches('.*trih.*')) ||
          getUserData().tenantId.lower().matches('.*_' + tenantId.lower()) ||
          tenantId.lower().matches('.*_' + getUserData().tenantId.lower()) ||
          ((getUserData().tenantId.lower().matches('.*rw26.*') || getUserData().tenantId.lower().matches('.*berjuang.*')) && 
           (tenantId.lower().matches('.*rw26.*') || tenantId.lower().matches('.*berjuang.*')) && (
             (getUserData().tenantId.lower().matches('.*rt0?1.*') && tenantId.lower().matches('.*rt0?1.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?2.*') && tenantId.lower().matches('.*rt0?2.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?3.*') && tenantId.lower().matches('.*rt0?3.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?4.*') && tenantId.lower().matches('.*rt0?4.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?5.*') && tenantId.lower().matches('.*rt0?5.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?6.*') && tenantId.lower().matches('.*rt0?6.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?7.*') && tenantId.lower().matches('.*rt0?7.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?8.*') && tenantId.lower().matches('.*rt0?8.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?9.*') && tenantId.lower().matches('.*rt0?9.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?10.*') && tenantId.lower().matches('.*rt0?10.*'))
          )) ||
          (getUserData().tenantId.lower().matches('.*trih.*') && tenantId.lower().matches('.*trih.*') && (
             (getUserData().tenantId.lower().matches('.*rt0?1.*') && tenantId.lower().matches('.*rt0?1.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?2.*') && tenantId.lower().matches('.*rt0?2.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?3.*') && tenantId.lower().matches('.*rt0?3.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?4.*') && tenantId.lower().matches('.*rt0?4.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?5.*') && tenantId.lower().matches('.*rt0?5.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?6.*') && tenantId.lower().matches('.*rt0?6.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?7.*') && tenantId.lower().matches('.*rt0?7.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?8.*') && tenantId.lower().matches('.*rt0?8.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?9.*') && tenantId.lower().matches('.*rt0?9.*')) ||
             (getUserData().tenantId.lower().matches('.*rt0?10.*') && tenantId.lower().matches('.*rt0?10.*'))
          ))
        )) ||
        ('email' in request.auth.token && request.auth.token.email.lower() == tenantId.lower() + "@gmail.com")
      );
    }

    function isPengurus() {
      return isSignedIn() && getUserData() != null && (
        getUserData().role in ['RT', 'RW', 'BENDAHARA', 'SEKRETARIS', 'KADER', 'KETUA RT', 'KETUA RW', 'PENGURUS', 'SUPER_ADMIN', 'ADMIN', 'rt', 'rw', 'bendahara', 'sekretaris', 'kader', 'ketua rt', 'ketua rw', 'pengurus', 'super_admin', 'admin'] ||
        ('role' in getUserData() && getUserData().role is string && getUserData().role.lower().matches('.*(rt|rw|bendahara|sekretaris|kader|admin|pengurus|super_admin).*')) ||
        getUserData().tenantId == 'MASTER'
      );
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /tenants/{tenantId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isAdmin() || (isPengurus() && isTenantMember(tenantId));
    }

    match /data_warga/{nik} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isPengurus() || isAdmin());
    }

    match /verifikasi_warga/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /surat/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (
        isSignedIn() && (
          (resource != null && (
            resource.data.authUid == request.auth.uid || 
            resource.data.userId == request.auth.uid || 
            (getUserData() != null && 'nik' in getUserData() && resource.data.nik == getUserData().nik)
          )) ||
          (isPengurus() && isTenantMember(resource.data.tenantId))
        )
      );
    }

    match /kas/{id} {
      allow read: if isSignedIn();
      allow write: if isPengurus() && isTenantMember(request.resource.data.tenantId);
    }

    match /iuran/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if (isPengurus() && isTenantMember(resource.data.tenantId)) || (
        isSignedIn() && resource != null && (
          resource.data.userId == request.auth.uid ||
          resource.data.recordedBy == request.auth.uid ||
          (getUserData() != null && 'nik' in getUserData() && resource.data.nik == getUserData().nik) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.nik == resource.data.nik) ||
          (exists(/databases/$(database)/documents/data_warga/$(request.auth.uid)) && get(/databases/$(database)/documents/data_warga/$(request.auth.uid)).data.nik == resource.data.nik)
        )
      );
    }

    match /branding/{tenantId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /toko_products/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /chat_messages/{id} {
      allow read: if isSignedIn();
      allow create: if isTenantMember(request.resource.data.tenantId);
    }

    match /complaints/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if (isPengurus() && isTenantMember(resource.data.tenantId)) || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /emergencies/{id} {
      allow read, write: if isSignedIn();
    }

    match /emergency_logs/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    match /subscriptions/{tenantId} {
      allow read, write: if isSignedIn();
    }

    match /push_subscriptions/{subId} {
      allow read, write: if true;
    }

    match /mading/{id} {
      allow read: if true;
      allow write: if isPengurus();
    }
    
    match /settings/{docId} {
      allow read, write: if true;
    }

    match /tenant_settings/{tenantId} {
      allow read, write: if isSignedIn();
    }

    // Catch-all
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
