rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || request.auth.token.email == 'arifrajcoach@gmail.com'); }
    function isOwner(resourceData) { return isSignedIn() && request.auth.uid == resourceData.authUid; }
    function isPengurus() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN', 'RT', 'RW', 'BENDAHARA', 'SEKRETARIS'])
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }
    
    match /tenant_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /tenants/{docId} {
      allow read, write: if isAdmin();
    }

    match /inventaris/{docId} {
      allow read, write: if isPengurus();
    }

    match /inventaris_kategori/{docId} {
      allow read, write: if isPengurus();
    }

    match /inventaris_lokasi/{docId} {
      allow read, write: if isPengurus();
    }

    match /inventaris_supplier/{docId} {
      allow read, write: if isPengurus();
    }

    match /iuran/{docId} {
      allow read, write: if isPengurus();
    }

    match /sampah_tarik_saldo/{docId} {
      allow read, write: if isPengurus();
    }

    match /posyandu_kegiatan/{docId} {
      allow read, write: if isPengurus();
    }

    match /posbindu_kegiatan/{docId} {
      allow read, write: if isPengurus();
    }

    match /pemeriksaan_balita/{docId} {
      allow read, write: if isPengurus();
    }
    
    match /pemeriksaan_posbindu/{docId} {
      allow read, write: if isPengurus();
    }

    match /emergencies/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow writing for SOS
    }

    match /inventaris_logs/{docId} {
      allow read, write: if isPengurus();
    }

    match /imunisasi/{docId} {
      allow read, write: if isPengurus();
    }

    match /ibu_hamil/{docId} {
      allow read, write: if isPengurus();
    }

    match /kas/{docId} {
      allow read, write: if isPengurus();
    }

    match /sampah_kategori/{docId} {
      allow read, write: if isPengurus();
    }

    match /surat/{docId} {
      allow read, write: if isPengurus();
    }


    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list: if isPengurus();
      allow read, write: if isAdmin(); // Admin override
    }

    match /verifikasi_warga/{docId} {
      // Allow get/update if user owns the record
      allow get, update: if (isSignedIn() && isOwner(resource.data)) || isAdmin();
      
      // Allow create if user sets their own authUid
      allow create: if isSignedIn() && (
        request.resource.data.authUid == request.auth.uid || isAdmin()
      );
      
      // Allow list ONLY if it's their own document
      allow list: if isAdmin() || (isSignedIn() && resource.data.authUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /balita/{docId} {
      allow read, write: if isPengurus();
    }

    match /sampah_setoran/{docId} {
      allow read, write: if isPengurus();
    }

    match /warga/{docId} {
      allow read, write: if isPengurus();
    }
    
    match /data_warga/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }
  }
}
