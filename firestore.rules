rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      // Untuk demo kita izinkan yang tidak verifikasi dulu jika testing, 
      // tapi idealnya: return request.auth.token.email_verified == true;
      return isSignedIn();
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      // Use data.get() to safely access fields with a default value to prevent rule crashes
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'Viewer') == 'Admin';
    }

    function isOperator() {
      let role = isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
                 get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'Viewer') : 'Viewer';
      return role == 'Operator' || role == 'Admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    (incoming().role == 'Viewer' || 
                     (request.auth.token.email == 'admin@rw26.com' && incoming().role == 'Admin') || 
                     (request.auth.token.email == 'arifrajcoach@gmail.com' && incoming().role == 'Admin') || 
                     (request.auth.token.email == 'operator@rw26.com' && incoming().role == 'Operator'));
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && 
                    !incoming().diff(existing()).affectedKeys().hasAny(['role']));
    }

    // --- Warga Collection ---
    match /warga/{nik} {
      allow read: if isSignedIn();
      allow create, update: if isOperator() && isValidId(nik) && 
                            incoming().nama is string && incoming().nama.size() <= 100;
      allow delete: if isAdmin();
    }

    // --- Kas Collection ---
    match /kas/{id} {
      allow read: if isSignedIn();
      allow create: if isOperator() && isValidId(id) &&
                    incoming().tipe in ['Masuk', 'Keluar'] &&
                    incoming().debit is number && incoming().kredit is number;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Surat Collection ---
    match /surat/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(id) &&
                    incoming().status == 'Diajukan' &&
                    incoming().pemohon is string;
      allow update: if isOperator() && 
                    (existing().status == 'Diajukan' || isAdmin()) &&
                    incoming().status in ['Diajukan', 'Selesai', 'Ditolak'];
      allow delete: if isAdmin();
    }

    // --- Iuran Collection ---
    match /iuran/{id} {
      allow read: if isSignedIn();
      allow create: if isOperator() && isValidId(id) &&
                    incoming().nominal is number && incoming().nominal > 0;
      allow update: if isOperator() &&
                    incoming().nominal == existing().nominal; // Nominal immutable usually
      allow delete: if isAdmin();
    }
  }
}
