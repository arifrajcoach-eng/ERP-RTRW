rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function getTenantId() {
      let user = getUserData();
      return user != null ? user.get('tenantId', 'RW26_SMART') : 'RW26_SMART';
    }

    function isSameTenant(data) {
      return data.get('tenantId', 'RW26_SMART') == getTenantId();
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'arifrajcoach@gmail.com' || 
        (getUserData() != null && getUserData().get('isSuperAdmin', false) == true)
      );
    }

    function isAdmin() {
      let user = getUserData();
      return isSignedIn() && (
        isSuperAdmin() || 
        (user != null && (user.get('role', 'Viewer') == 'ADMIN' || user.get('role', 'Viewer') == 'RW'))
      );
    }

    function isOperator() {
      let user = getUserData();
      let role = user != null ? user.get('role', 'Viewer') : 'Viewer';
      return isSuperAdmin() || role == 'ADMIN' || role == 'RW' || role == 'RT' || role == 'BENDAHARA' || role == 'SEKRETARIS';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidWarga(data) {
      return data.nik is string && data.nik.size() >= 1 &&
             data.nama is string && data.nama.size() <= 100 &&
             data.tenantId is string && data.tenantId.size() <= 50;
    }

    function isValidKas(data) {
      return (data.get('debit', 0) is number || data.get('kredit', 0) is number) &&
             data.tipe in ['Masuk', 'Keluar'] &&
             data.tanggal is string &&
             data.tenantId is string;
    }

    function isValidSurat(data) {
      return data.id is string &&
             data.pemohon is string &&
             data.status in ['Diajukan', 'Draft', 'Terkirim', 'Selesai', 'Ditolak'] &&
             data.tenantId is string;
    }

    function isValidIuran(data) {
      return data.nominal is number &&
             data.status in ['Lunas', 'Pending'] &&
             data.nama is string &&
             data.tenantId is string;
    }

    function isValidInventaris(data) {
      return data.nama_barang is string &&
             data.kategori is string &&
             data.lokasi is string &&
             data.stok is number &&
             data.tenantId is string;
    }

    function isValidInventarisLog(data) {
      return data.itemId is string &&
             data.aktivitas is string &&
             data.tanggal is string &&
             data.tenantId is string;
    }

    function isValidKategori(data) {
      return data.nama_kategori is string && data.tenantId is string;
    }

    function isValidLokasi(data) {
      return data.nama_lokasi is string && data.tenantId is string;
    }

    function isValidSupplier(data) {
      return data.nama is string && data.tenantId is string;
    }

    function isValidBalita(data) {
      return data.nama is string && data.tglLahir is string && data.jk in ['Laki-Laki', 'Perempuan'] && data.orangTuaId is string && data.tenantId is string;
    }

    function isValidIbuHamil(data) {
      return data.nama is string && data.nik is string && data.tenantId is string;
    }

    function isValidPosyanduKegiatan(data) {
      return data.tanggal is string && data.lokasi is string && data.tenantId is string;
    }

    function isValidPemeriksaan(data) {
      return data.balitaId is string && data.tanggal is string && (data.beratBadan is number || data.tinggiBadan is number) && data.tenantId is string;
    }

    function isValidImunisasi(data) {
      return data.balitaId is string && data.jenisImunisasi is string && data.tanggal is string && data.tenantId is string;
    }

    function isValidSampahKategori(data) {
      return data.nama is string && data.satuan in ['kg', 'liter', 'pcs'] && data.hargaBeli is number && data.tenantId is string;
    }

    function isValidSampahSetoran(data) {
      return data.nasabahId is string && data.kategoriId is string && data.berat is number && data.total is number && data.tanggal is string && data.tenantId is string;
    }

    function isValidSampahTarik(data) {
      return data.nasabahId is string && data.nominal is number && data.tanggal is string && data.tenantId is string;
    }

    function isValidEmergency(data) {
      return data.userName is string && data.status in ['ACTIVE', 'RESOLVED'] && data.tenantId is string;
    }

    // --- Tenants Collection ---
    match /tenants/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // --- Settings Collection ---
    match /settings/{tId} {
      allow read: if isSignedIn() && (isSuperAdmin() || tId == getTenantId());
      allow write: if isAdmin() && tId == getTenantId();
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn() && (isSuperAdmin() || request.auth.uid == userId || isSameTenant(existing()));
      allow create: if isSignedIn() && (
        isSuperAdmin() || 
        (request.auth.uid == userId && incoming().get('role', 'RT') == 'RT') || 
        (isAdmin() && incoming().get('tenantId', '') == getTenantId())
      );
      allow update: if isSuperAdmin() || (isAdmin() && existing().get('tenantId', '') == getTenantId()) || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isSuperAdmin() || (isAdmin() && existing().get('tenantId', '') == getTenantId());
    }

    // --- Data Warga Collection ---
    match /data_warga/{nik} {
      allow read: if isSignedIn() && (isSuperAdmin() || (isSameTenant(existing()) && (getUserData().get('role', '') != 'RT' || existing().get('rt', '') == getUserData().get('rt', ''))));
      allow create: if isOperator() && isValidId(nik) && isValidWarga(incoming()) && isSameTenant(incoming()) && (isSuperAdmin() || getUserData().get('role', '') != 'RT' || incoming().get('rt', '') == getUserData().get('rt', ''));
      allow update: if isOperator() && isValidId(nik) && isValidWarga(incoming()) && isSameTenant(existing()) && isSameTenant(incoming()) && (isSuperAdmin() || getUserData().get('role', '') != 'RT' || (existing().get('rt', '') == getUserData().get('rt', '') && incoming().get('rt', '') == getUserData().get('rt', '')));
      allow delete: if isAdmin();
    }

    // --- Kas Collection ---
    match /kas/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || (isSameTenant(existing()) && (getUserData().get('role', '') != 'RT' || existing().get('rt', '') == getUserData().get('rt', ''))));
      allow create: if isOperator() && isValidId(id) && isValidKas(incoming()) && isSameTenant(incoming()) && (isSuperAdmin() || getUserData().get('role', '') != 'RT' || incoming().get('rt', '') == getUserData().get('rt', ''));
      allow update: if isOperator() && isValidKas(incoming()) && isSameTenant(existing()) && isSameTenant(incoming()) && (isSuperAdmin() || getUserData().get('role', '') != 'RT' || (existing().get('rt', '') == getUserData().get('rt', '') && incoming().get('rt', '') == getUserData().get('rt', '')));
      allow delete: if isAdmin();
    }

    // --- Surat Collection ---
    match /surat/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || (isSameTenant(existing()) && (getUserData().get('role', '') != 'RT' || existing().get('rt', '') == getUserData().get('rt', ''))));
      allow create: if isSignedIn() && isValidId(id) && isValidSurat(incoming()) && isSameTenant(incoming()) && (isSuperAdmin() || getUserData().get('role', '') != 'RT' || incoming().get('rt', '') == getUserData().get('rt', ''));
      allow update: if isOperator() && isValidSurat(incoming()) && isSameTenant(existing()) && isSameTenant(incoming()) && (isSuperAdmin() || getUserData().get('role', '') != 'RT' || (existing().get('rt', '') == getUserData().get('rt', '') && incoming().get('rt', '') == getUserData().get('rt', '')));
      allow delete: if isAdmin();
    }

    // --- Iuran Collection ---
    match /iuran/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || (isSameTenant(existing()) && (getUserData().get('role', '') != 'RT' || existing().get('rt', '') == getUserData().get('rt', ''))));
      allow create: if isOperator() && isValidId(id) && isValidIuran(incoming()) && isSameTenant(incoming()) && (isSuperAdmin() || getUserData().get('role', '') != 'RT' || incoming().get('rt', '') == getUserData().get('rt', ''));
      allow update: if isOperator() && isValidIuran(incoming()) && isSameTenant(existing()) && isSameTenant(incoming()) && (isSuperAdmin() || getUserData().get('role', '') != 'RT' || (existing().get('rt', '') == getUserData().get('rt', '') && incoming().get('rt', '') == getUserData().get('rt', '')));
      allow delete: if isAdmin();
    }

    // --- Inventaris Collection ---
    match /inventaris/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidInventaris(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidInventaris(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    // --- Inventaris Logs Collection ---
    match /inventaris_logs/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidInventarisLog(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidInventarisLog(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /inventaris_kategori/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidKategori(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidKategori(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /inventaris_lokasi/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidLokasi(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidLokasi(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /inventaris_supplier/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidSupplier(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidSupplier(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    // --- Posyandu Collections ---
    match /balita/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidBalita(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidId(id) && isValidBalita(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /ibu_hamil/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidIbuHamil(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidId(id) && isValidIbuHamil(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /posyandu_kegiatan/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidPosyanduKegiatan(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidId(id) && isValidPosyanduKegiatan(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /pemeriksaan_balita/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidPemeriksaan(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidId(id) && isValidPemeriksaan(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /imunisasi/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidImunisasi(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidId(id) && isValidImunisasi(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /sampah_kategori/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidSampahKategori(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidId(id) && isValidSampahKategori(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /sampah_setoran/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidSampahSetoran(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidId(id) && isValidSampahSetoran(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    match /sampah_tarik_saldo/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isOperator() && isValidId(id) && isValidSampahTarik(incoming()) && isSameTenant(incoming());
      allow update: if isOperator() && isValidId(id) && isValidSampahTarik(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    // --- Emergency Collections ---
    match /emergencies/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isSignedIn() && isValidId(id) && isValidEmergency(incoming()) && isSameTenant(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid)) && isValidEmergency(incoming()) && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }

    // --- Branding and Template Collections ---
    match /tenant_settings/{tId} {
      allow read: if isSignedIn() && (isSuperAdmin() || tId == getTenantId());
      allow write: if isAdmin() && tId == getTenantId();
    }

    match /kop_settings/{tId} {
      allow read: if isSignedIn() && (isSuperAdmin() || tId == getTenantId());
      allow write: if isAdmin() && tId == getTenantId();
    }

    match /templates/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isSameTenant(existing()));
      allow create: if isAdmin() && isValidId(id) && isSameTenant(incoming());
      allow update: if isAdmin() && isSameTenant(existing()) && isSameTenant(incoming());
      allow delete: if isAdmin();
    }
  }
}
