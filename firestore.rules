rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Default Deny (First) ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : (
          (isSignedIn() && 'email' in request.auth.token && request.auth.token.email != null && exists(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lower())))
            ? get(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lower())).data
            : null
        );
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == 'arifrajcoach@gmail.com') || 
        request.auth.uid == 'eHFrJ7Re1sb4xhMWlsHNoKr5qs53' ||
        request.auth.uid == 'MKe94buSU4SMg8jiRbCcOLwJp9H3' ||
        request.auth.uid == 'zdXsW4N3qFcHpDoBynAoO2GgbYA2' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    function isAdminStatic() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == 'arifrajcoach@gmail.com') || 
        request.auth.uid in [
          'eHFrJ7Re1sb4xhMWlsHNoKr5qs53',
          'MKe94buSU4SMg8jiRbCcOLwJp9H3',
          'zdXsW4N3qFcHpDoBynAoO2GgbYA2'
        ]
      );
    }
    
    function isTenantMemberStatic(tenantId) {
      let isString = tenantId is string;
      let isCommon = isString && tenantId in ['trihprw26', 'MASTER', 'master', 'rt01_rw26_berjuang', 'rt02_rw26_berjuang', 'rt03_rw26_berjuang', 'rt04_rw26_berjuang', 'rt05_rw26_berjuang'];
      return isSignedIn() && isString && (
        isAdminStatic() ||
        ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == 'arifrajcoach@gmail.com') || 
        request.auth.uid == 'eHFrJ7Re1sb4xhMWlsHNoKr5qs53' ||
        request.auth.uid == 'MKe94buSU4SMg8jiRbCcOLwJp9H3' ||
        request.auth.uid == 'zdXsW4N3qFcHpDoBynAoO2GgbYA2' ||
        
        // Group access
        (
          (
            ('tenantId' in request.auth.token && request.auth.token.tenantId != null && (
              isCommon ||
              request.auth.token.tenantId.lower() in ['trihprw26', 'master'] ||
              request.auth.token.tenantId.lower().matches('^rt[0-9]+_rw26_berjuang$') ||
              request.auth.token.tenantId.lower().matches('^rt[0-9]+_trih.*') ||
              request.auth.token.tenantId.lower().matches('.*berjuang.*') ||
              request.auth.token.tenantId.lower().matches('.*trih.*')
            )) ||
            ('email' in request.auth.token && request.auth.token.email != null && (
              request.auth.token.email.lower().matches('^rt[0-9]+@rw26_berjuang\\.com$') ||
              request.auth.token.email.lower().matches('^rt[0-9]+@trih.*') ||
              request.auth.token.email.lower().matches('.*berjuang.*|.*trih.*')
            ))
          ) && (
            isCommon ||
            tenantId.lower() in ['trihprw26', 'master'] ||
            tenantId.lower().matches('^rt[0-9]+_rw26_berjuang$') ||
            tenantId.lower().matches('^rt[0-9]+_trih.*') ||
            tenantId.lower().matches('.*berjuang.*') ||
            tenantId.lower().matches('.*trih.*')
          )
        ) ||

        ('firebase' in request.auth.token && 'sign_in_provider' in request.auth.token.firebase && request.auth.token.firebase.sign_in_provider == 'anonymous' && (
          isCommon ||
          tenantId.lower() in ['trihprw26', 'master'] ||
          tenantId.lower().matches('^rt[0-9]+_trih.*') ||
          tenantId.lower().matches('.*berjuang.*') ||
          tenantId.lower().matches('.*trih.*')
        )) ||
        
        ('tenantId' in request.auth.token && request.auth.token.tenantId != null && (
          request.auth.token.tenantId == tenantId ||
          request.auth.token.tenantId.lower() == tenantId.lower()
        )) ||
        
        ('firebase' in request.auth.token && 'tenant' in request.auth.token.firebase && request.auth.token.firebase.tenant != null && (
          request.auth.token.firebase.tenant == tenantId ||
          request.auth.token.firebase.tenant.lower() == tenantId.lower()
        )) ||
        
        ('email' in request.auth.token && request.auth.token.email != null && (
          request.auth.token.email.lower() == tenantId.lower() ||
          request.auth.token.email.lower() == tenantId.lower() + '@gmail.com' ||
          request.auth.token.email.lower() == tenantId.lower() + '@trihprw26.com' ||
          request.auth.token.email.lower().matches('^' + tenantId.lower() + '.*') ||
          request.auth.token.email.lower().matches('^' + tenantId.lower() + '@.*') ||
          request.auth.token.email.lower().matches('^' + tenantId.lower() + '_.*') ||
          request.auth.token.email.lower().matches('^' + tenantId.lower() + '-.*')
        ))
      );
    }

    function isTenantMember(tenantId) {
      return tenantId is string && (isTenantMemberStatic(tenantId) || (
        isSignedIn() && (
          getUserData() != null && 'tenantId' in getUserData() && getUserData().tenantId != null && (
            getUserData().tenantId == 'MASTER' || 
            getUserData().tenantId == 'master' ||
            getUserData().tenantId == tenantId || 
            getUserData().tenantId.lower() == tenantId.lower() || 
            
            // Allow sub-tenant to read parent (flexible across ecosystem)
            (getUserData().tenantId.lower().matches('^rt[0-9]+_rw26_berjuang$') && (tenantId.lower() in ['trihprw26', 'rw26_berjuang'])) ||
            (getUserData().tenantId.lower().matches('^rt[0-9]+_trih.*') && (tenantId.lower() in ['trihprw26'])) ||

            // Allow parent to access sub-tenants (bidirectional)
            ((getUserData().tenantId.lower() in ['trihprw26', 'rw26_berjuang']) && (
              tenantId.lower().matches('^rt[0-9]+_rw26_berjuang$') ||
              tenantId.lower().matches('^rt[0-9]+_trih.*')
            )) ||

            (getUserData().tenantId == 'trihprw26' && (tenantId in ['trihprw26']))
          )
        )
      ));
    }
    
    function isPengurusStatic() {
      return isSignedIn() && (
        isAdminStatic() ||
        ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email == 'arifrajcoach@gmail.com') || 
        request.auth.uid == 'eHFrJ7Re1sb4xhMWlsHNoKr5qs53' ||
        request.auth.uid == 'MKe94buSU4SMg8jiRbCcOLwJp9H3' ||
        request.auth.uid == 'zdXsW4N3qFcHpDoBynAoO2GgbYA2' ||
        ('email' in request.auth.token && request.auth.token.email != null && (
          request.auth.token.email.lower().matches('^rt.*') ||
          request.auth.token.email.lower().matches('^rw.*') ||
          request.auth.token.email.lower().matches('^admin.*') ||
          request.auth.token.email.lower().matches('^kader.*') ||
          request.auth.token.email.lower().matches('^trih.*') ||
          request.auth.token.email.lower().matches('^berjuang.*') ||
          request.auth.token.email.lower() == 'rt01@rw26.com'
        ))
      );
    }

    function isPengurus() {
      return isPengurusStatic() || (
        isSignedIn() && (
          getUserData() != null && (
            ('role' in getUserData() && getUserData().role in ['ADMIN', 'SUPER_ADMIN', 'RT', 'RW', 'BENDAHARA', 'SEKRETARIS', 'KADER', 'KETUA RT', 'KETUA RW', 'ADMIN RT', 'ADMIN RW', 'PENGURUS', 'KETUA']) ||
            ('tenantId' in getUserData() && (getUserData().tenantId == 'MASTER' || getUserData().tenantId == 'master'))
          )
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Core Collections ---

    match /settings/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow create: if true; // Allow anyone to initiate registration
      allow update: if isPengurus() && isTenantMember(tenantId);
    }

    match /tenant_settings/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow write: if isPengurus() && isTenantMember(tenantId);
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if true; // Allow anyone to initiate registration
      allow update: if isAdmin() || (isPengurus() && isTenantMember(tenantId));
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if true; // Allow new user creation during registration
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() ||
        (isPengurus() && 
         'tenantId' in resource.data && resource.data.tenantId != null && isTenantMember(resource.data.tenantId) &&
         'tenantId' in request.resource.data && request.resource.data.tenantId != null && isTenantMember(request.resource.data.tenantId))
      );
      allow delete: if isSignedIn() && (
        isAdmin() ||
        (isPengurus() && 'tenantId' in resource.data && resource.data.tenantId != null && isTenantMember(resource.data.tenantId))
      );
    }

    match /public_usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Toko & Commerce ---

    match /toko_products/{docId} {
      allow read: if isSignedIn();
      allow create: if isPengurus() && 'tenantId' in request.resource.data && isTenantMember(request.resource.data.tenantId);
      allow update: if isPengurus() && 'tenantId' in request.resource.data && isTenantMember(request.resource.data.tenantId) && 'tenantId' in resource.data && isTenantMember(resource.data.tenantId);
      allow delete: if isPengurus() && 'tenantId' in resource.data && isTenantMember(resource.data.tenantId);
    }

    match /toko_products_seller/{docId} {
      allow list: if isTenantMemberStatic(resource.data.tenantId);
      allow get: if isTenantMember(resource.data.tenantId);
      allow create: if isPengurus() && 'tenantId' in request.resource.data && isTenantMember(request.resource.data.tenantId);
      allow update: if isPengurus() && 'tenantId' in request.resource.data && isTenantMember(request.resource.data.tenantId) && 'tenantId' in resource.data && isTenantMember(resource.data.tenantId);
      allow delete: if isPengurus() && 'tenantId' in resource.data && isTenantMember(resource.data.tenantId);
    }

    match /toko_orders/{docId} {
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isTenantMemberStatic(resource.data.tenantId));
      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || isTenantMember(resource.data.tenantId));
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && resource.data.customerId == request.auth.uid) || (isPengurus() && isTenantMember(resource.data.tenantId));
      allow delete: if isAdmin();
    }

    match /toko_reviews/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /ppob_trx/{docId} {
      allow list: if isTenantMemberStatic(resource.data.tenantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isTenantMember(resource.data.tenantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }

    // --- Warga & Kependudukan ---

    match /data_warga/{docId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() || resource == null;
      allow create: if isSignedIn() && (
        isAdmin() || 
        isAdminStatic() || 
        ('tenantId' in request.resource.data && request.resource.data.tenantId is string && isTenantMember(request.resource.data.tenantId))
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        isAdminStatic() || 
        (
          ('tenantId' in request.resource.data && request.resource.data.tenantId is string && isTenantMember(request.resource.data.tenantId)) && 
          (resource == null || !('tenantId' in resource.data) || resource.data.tenantId == null || (resource.data.tenantId is string && isTenantMember(resource.data.tenantId)))
        )
      );
      allow delete: if isSignedIn() && (
        isAdmin() || 
        isAdminStatic() || 
        (resource == null || !('tenantId' in resource.data) || resource.data.tenantId == null || (resource.data.tenantId is string && isTenantMember(resource.data.tenantId)))
      );
    }

    match /verifikasi_warga/{docId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isPengurus() && isTenantMember(resource.data.tenantId));
    }

    // --- Keuangan & Layanan ---

    match /kas/{docId} {
      allow list: if isTenantMemberStatic(resource.data.tenantId);
      allow get: if isTenantMember(resource.data.tenantId);
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }

    match /iuran/{docId} {
      allow list: if isTenantMemberStatic(resource.data.tenantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isTenantMember(resource.data.tenantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isTenantMember(resource.data.tenantId);
    }

    match /surat/{docId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isAdminStatic() || (
        isSignedIn() && (
          // Is owner/creator of the document (akun warga pada E-Administrasi)
          (resource != null && (
            resource.data.authUid == request.auth.uid || 
            resource.data.userId == request.auth.uid || 
            (getUserData() != null && 'nik' in getUserData() && resource.data.nik == getUserData().nik)
          )) ||
          // Or is an administrative officer (akun warga pada RW / pengurus)
          (getUserData() != null && (
            getUserData().role in ['SUPER_ADMIN', 'ADMIN'] ||
            ('tenantId' in getUserData() && (getUserData().tenantId == 'MASTER' || getUserData().tenantId == 'master')) ||
            (isPengurus() && isTenantMember(resource.data.tenantId))
          ))
        )
      );
    }

    // --- Social & Interaction ---

    match /chat_messages/{docId} {
      allow list: if isTenantMemberStatic(resource.data.tenantId);
      allow get: if isTenantMember(resource.data.tenantId);
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }

    match /buku_tamu/{docId} {
      allow list: if isTenantMemberStatic(resource.data.tenantId);
      allow get: if isSignedIn();
      allow create: if true;
      allow update, delete: if isTenantMember(resource.data.tenantId);
    }

    match /emergencies/{docId} {
      allow list: if isSignedIn();
      allow get: if isTenantMember(resource.data.tenantId);
      allow create: if isSignedIn();
      allow update: if isTenantMember(resource.data.tenantId) || 
                       (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /complaints/{docId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantMemberStatic(resource.data.tenantId));
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantMember(resource.data.tenantId));
      allow create: if isSignedIn();
      allow update: if isPengurus() && isTenantMember(resource.data.tenantId);
    }

    match /mading/{docId} {
      allow list: if isSignedIn() && isTenantMemberStatic(resource.data.tenantId);
      allow get: if isSignedIn() && isTenantMember(resource.data.tenantId);
      allow create: if isPengurus() && isTenantMember(request.resource.data.tenantId);
      allow update: if isPengurus() && isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isPengurus() && isTenantMember(resource.data.tenantId);
    }

    match /organisasi_struktur/{docId} {
      allow read: if isTenantMember(docId);
      allow write: if isPengurus() && isTenantMember(docId);
    }

    match /bookings/{docId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantMemberStatic(resource.data.tenantId));
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantMember(resource.data.tenantId));
      allow create: if isSignedIn();
      allow update: if isPengurus() && isTenantMember(resource.data.tenantId);
    }

    match /voting_candidates/{docId} {
      allow read: if isSignedIn();
      allow create: if isPengurus() && isTenantMember(request.resource.data.tenantId);
      allow update: if isPengurus() && isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isPengurus() && isTenantMember(resource.data.tenantId);
    }

    match /voting_config/{docId} {
      allow list: if isTenantMemberStatic(docId);
      allow get: if isTenantMember(docId);
      allow write: if isPengurus() && isTenantMember(docId);
    }

    match /voting_votes/{docId} {
      allow list: if isSignedIn() && (resource.data.voterId == request.auth.uid || isTenantMemberStatic(resource.data.tenantId));
      allow get: if isSignedIn() && (resource.data.voterId == request.auth.uid || isTenantMember(resource.data.tenantId));
      allow create: if isSignedIn();
    }

    // --- Infrastructure & Misc ---

    match /inventaris/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /inventaris_logs/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /inventaris_kategori/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /inventaris_lokasi/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /inventaris_supplier/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }

    match /notifications/{docId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantMemberStatic(resource.data.tenantId));
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantMember(resource.data.tenantId));
      allow create: if isPengurus() && isTenantMember(request.resource.data.tenantId);
      allow update: if isPengurus() && isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isPengurus() && isTenantMember(resource.data.tenantId);
    }
    
    match /audit_logs/{docId} {
      allow list: if isAdminStatic() || (isPengurusStatic() && isTenantMemberStatic(resource.data.tenantId));
      allow get: if isAdmin() || (isPengurus() && isTenantMember(resource.data.tenantId));
      allow create: if isSignedIn();
    }
    
    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Health & Social Programs ---
    match /balita/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /ibu_hamil/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /posyandu_kegiatan/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /posbindu_kegiatan/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /pemeriksaan_balita/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /pemeriksaan_posbindu/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /imunisasi/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /lansia/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /warga_sakit/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    
    // --- Environment & Waste ---
    match /sampah_kategori/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /sampah_setoran/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /sampah_tarik_saldo/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /sampah_nasabah/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    
    // --- Admin/System Collections ---
    match /monthly_reports/{docId} {
      allow list: if isTenantMemberStatic(resource.data.tenantId);
      allow get: if isTenantMember(resource.data.tenantId);
      allow write: if isAdmin();
    }
    // --- Layanan Kependudukan ---
    match /kelahiran/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }
    match /kematian/{docId} {
      allow list: if isSignedIn() && (isTenantMemberStatic(resource.data.tenantId) || isAdminStatic());
      allow get: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow create: if isTenantMember(request.resource.data.tenantId);
      allow update: if isTenantMember(request.resource.data.tenantId) && isTenantMember(resource.data.tenantId);
      allow delete: if isTenantMember(resource.data.tenantId);
    }

    match /usage_logs/{docId} {
      allow list: if isTenantMemberStatic(resource.data.tenantId);
      allow get: if isTenantMember(resource.data.tenantId);
      allow write: if isAdmin();
    }
    match /ai_usage_logs/{docId} { allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()); }
    match /ai_cache/{docId} { allow read, write: if isSignedIn(); }
    match /tenant_registrations/{docId} { 
      allow read: if isSignedIn() && (isAdmin() || ('email' in request.auth.token && docId == request.auth.token.email));
      allow create: if true; 
      allow update: if isSignedIn() && (isAdmin() || ('email' in request.auth.token && docId == request.auth.token.email));
    }

  }
}
