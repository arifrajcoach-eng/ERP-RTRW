rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Default Deny (First) ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : (
          (isSignedIn() && 'email' in request.auth.token && request.auth.token.email != null && exists(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lower())))
            ? get(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lower())).data
            : null
        );
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'arifrajcoach@gmail.com') || 
        request.auth.uid == 'eHFrJ7Re1sb4xhMWlsHNoKr5qs53' ||
        request.auth.uid == 'MKe94buSU4SMg8jiRbCcOLwJp9H3' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    
    function isTenantMember(tenantId) {
      return isSignedIn() && (
        isAdmin() || 
        (request.auth.token.firebase.sign_in_provider == 'anonymous' && (tenantId in ['RW26_SMART', 'RW_BERJUANG', 'trihprw26'])) ||
        (getUserData() != null && (
          getUserData().tenantId == tenantId || 
          (getUserData().tenantId == 'RW_BERJUANG' && (tenantId in ['trihprw26', 'RW_BERJUANG', 'RW26_SMART'])) ||
          (getUserData().tenantId == 'trihprw26' && (tenantId in ['RW_BERJUANG', 'trihprw26', 'RW26_SMART'])) ||
          (getUserData().tenantId == 'RW26_SMART' && (tenantId in ['RW26_SMART', 'RW_BERJUANG', 'trihprw26']))
        ))
      );
    }
    
    function isPengurus() {
      return isSignedIn() && (
        isAdmin() || 
        (getUserData() != null && (getUserData().role in ['ADMIN', 'SUPER_ADMIN', 'RT', 'RW', 'BENDAHARA', 'SEKRETARIS']))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Core Collections ---

    match /settings/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow write: if isPengurus() && isTenantMember(tenantId);
    }

    match /tenant_settings/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow write: if isPengurus() && isTenantMember(tenantId);
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isPengurus() && isTenantMember(tenantId));
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /public_usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Toko & Commerce ---

    match /toko_products/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus() && isTenantMember(resource.data.tenantId || request.resource.data.tenantId);
    }

    match /toko_products_seller/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isPengurus() && isTenantMember(resource.data.tenantId || request.resource.data.tenantId);
    }

    match /toko_orders/{docId} {
      allow list, get: if isSignedIn() && (resource.data.customerId == request.auth.uid || isTenantMember(resource.data.tenantId));
      allow create: if isSignedIn();
      allow update: if isPengurus() && isTenantMember(resource.data.tenantId);
      allow delete: if isAdmin();
    }

    match /toko_reviews/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /ppob_trx/{docId} {
      allow list, get: if isTenantMember(resource.data.tenantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }

    // --- Warga & Kependudukan ---

    match /data_warga/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }

    match /verifikasi_warga/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || resource.data.authUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isTenantMember(resource.data.tenantId) || resource.data.authUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isPengurus() && isTenantMember(resource.data.tenantId));
    }

    // --- Keuangan & Layanan ---

    match /kas/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isTenantMember(resource.data.tenantId || request.resource.data.tenantId);
    }

    match /iuran/{docId} {
      allow read: if isTenantMember(resource.data.tenantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isTenantMember(resource.data.tenantId);
    }

    match /surat/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || request.auth.uid == resource.data.authUid);
      allow create: if isSignedIn();
      allow update, delete: if isPengurus() && isTenantMember(resource.data.tenantId);
    }

    // --- Social & Interaction ---

    match /chat_messages/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId) || isTenantMember(request.resource.data.tenantId);
    }

    match /buku_tamu/{docId} {
      allow list: if isTenantMember(resource.data.tenantId);
      allow get: if isSignedIn();
      allow create: if true;
      allow update, delete: if isTenantMember(resource.data.tenantId);
    }

    match /emergencies/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow create: if isSignedIn();
      allow update: if isTenantMember(resource.data.tenantId || request.resource.data.tenantId) || 
                       (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /complaints/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isPengurus());
      allow create: if isSignedIn();
      allow update: if isPengurus() && isTenantMember(resource.data.tenantId);
    }

    match /bookings/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantMember(resource.data.tenantId));
      allow create: if isSignedIn();
      allow update: if isPengurus() && isTenantMember(resource.data.tenantId);
    }

    match /voting_candidates/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus() && isTenantMember(resource.data.tenantId || request.resource.data.tenantId);
    }

    match /voting_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus() && isTenantMember(docId);
    }

    match /voting_votes/{docId} {
      allow list, get: if isSignedIn() && (resource.data.voterId == request.auth.uid || isPengurus());
      allow create: if isSignedIn();
    }

    // --- Infrastructure & Misc ---

    match /inventaris/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /inventaris_logs/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /inventaris_kategori/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /inventaris_lokasi/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /inventaris_supplier/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }

    match /notifications/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isTenantMember(resource.data.tenantId));
      allow write: if isPengurus() && isTenantMember(resource.data.tenantId || request.resource.data.tenantId);
    }
    
    match /audit_logs/{docId} {
      allow read: if isAdmin() || (isPengurus() && isTenantMember(resource.data.tenantId));
      allow create: if isSignedIn();
    }
    
    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Health & Social Programs ---
    match /balita/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /ibu_hamil/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /posyandu_kegiatan/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /posbindu_kegiatan/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /pemeriksaan_balita/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /pemeriksaan_posbindu/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /imunisasi/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /lansia/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /warga_sakit/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    
    // --- Environment & Waste ---
    match /sampah_kategori/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /sampah_setoran/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /sampah_tarik_saldo/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    match /sampah_nasabah/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || isAdmin());
      allow write: if isTenantMember(request.resource.data.tenantId || (resource != null ? resource.data.tenantId : null));
    }
    
    // --- Admin/System Collections ---
    match /monthly_reports/{docId} { allow read: if isTenantMember(resource.data.tenantId); allow write: if isAdmin(); }
    match /usage_logs/{docId} { allow read: if isTenantMember(resource.data.tenantId); allow write: if isAdmin(); }
    match /ai_usage_logs/{docId} { allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()); }
    match /ai_cache/{docId} { allow read, write: if isSignedIn(); }
    match /tenant_registrations/{docId} { 
      allow read: if isSignedIn() && (isAdmin() || ('email' in request.auth.token && docId == request.auth.token.email));
      allow create: if true; 
      allow update: if isSignedIn() && (isAdmin() || ('email' in request.auth.token && docId == request.auth.token.email));
    }

  }
}
