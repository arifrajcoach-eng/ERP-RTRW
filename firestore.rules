rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Unified Tenant/Role Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email == 'arifrajcoach@gmail.com' || 
        request.auth.uid == 'eHFrJ7Re1sb4xhMWlsHNoKr5qs53'
      ); 
    }
    
    function getRequestor() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isTenantMember(tenantId) {
      return isSignedIn() && (isAdmin() || getRequestor().tenantId == tenantId);
    }
    
    function isPengurus() {
      return isSignedIn() && (
        isAdmin() || 
        (getRequestor().role in ['ADMIN', 'SUPER_ADMIN', 'RT', 'RW', 'BENDAHARA', 'SEKRETARIS'])
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions (Legacy, to be removed) ---
    function getUser(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function isOwner(resourceData) { return isSignedIn() && request.auth.uid == resourceData.authUid; }

    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }
    
    match /tenant_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /buku_tamu/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
      allow create: if true;
    }

    match /tenant_registrations/{docId} {
      allow create: if true; // Public registration
      allow read, write: if isAdmin(); // Only admins can process
    }
    
    match /tenants/{docId} {
      allow read, write: if isAdmin();
    }

    match /inventaris/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_kategori/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_lokasi/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_supplier/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /iuran/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_tarik_saldo/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /posyandu_kegiatan/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /posbindu_kegiatan/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /pemeriksaan_balita/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }
    
    match /pemeriksaan_posbindu/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /emergencies/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow writing for SOS
    }

    match /inventaris_logs/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /imunisasi/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /ibu_hamil/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /kas/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_kategori/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /surat/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }


    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || (resource.data.email == request.auth.token.email));
      allow create, update, delete: if isPengurus() && isTenantMember(request.resource.data.tenantId);
      allow list: if isPengurus();
      allow read, write: if isAdmin(); // Admin override
    }

    match /public_usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /verifikasi_warga/{docId} {
      // Allow get/update if user owns the record
      allow get, update: if (isSignedIn() && isOwner(resource.data)) || isAdmin();
      
      // Allow create if user sets their own authUid
      allow create: if isSignedIn() && (
        request.resource.data.authUid == request.auth.uid || isAdmin()
      );
      
      // Allow list ONLY if it's their own document OR they are pengurus
      allow list: if isSignedIn(); // Relaxed to allow authenticated users to list
      allow delete: if isAdmin();
    }

    match /balita/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_setoran/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /warga/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /voting_candidates/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /voting_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /voting_votes/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isPengurus();
      allow delete: if isPengurus();
    }

    match /toko_products/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /toko_orders/{docId} {
      allow read: if isSignedIn() && (resource == null || resource.data.customerId == request.auth.uid || isPengurus());
      allow create: if isSignedIn();
      allow update: if isPengurus();
      allow delete: if isPengurus();
    }
    
    match /data_warga/{docId} {
      allow read: if isTenantMember(resource.data.tenantId);
      allow write: if isTenantMember(resource.data.tenantId);
    }
  }
}
