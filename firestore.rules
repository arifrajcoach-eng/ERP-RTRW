rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Unified Tenant/Role Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        ("email" in request.auth.token && request.auth.token.email == 'arifrajcoach@gmail.com') || 
        request.auth.uid == 'eHFrJ7Re1sb4xhMWlsHNoKr5qs53'
      ); 
    }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }
    
    function isTenantMember(tenantId) {
      let userData = getUserData();
      return isSignedIn() && (isAdmin() || (userData != null && userData.tenantId == tenantId));
    }
    
    function isPengurus() {
      let userData = getUserData();
      return isSignedIn() && (
        isAdmin() || 
        (userData != null && (userData.role in ['ADMIN', 'SUPER_ADMIN', 'RT', 'RW', 'BENDAHARA', 'SEKRETARIS']))
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions (Legacy, to be removed) ---
    function getUser(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function isOwner(resourceData) { return isSignedIn() && request.auth.uid == resourceData.authUid; }

    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }
    
    match /tenant_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /buku_tamu/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
      allow create: if true;
    }

    match /tenant_registrations/{docId} {
      allow create: if true; // Public registration
      allow read, write: if isAdmin(); // Only admins can process
    }
    
    match /tenants/{docId} {
      allow read, write: if isAdmin();
    }

    match /inventaris/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_kategori/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_lokasi/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /inventaris_supplier/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /iuran/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_tarik_saldo/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /posyandu_kegiatan/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /posbindu_kegiatan/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /pemeriksaan_balita/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }
    
    match /pemeriksaan_posbindu/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /emergencies/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow writing for SOS
    }

    match /inventaris_logs/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /imunisasi/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /ibu_hamil/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /kas/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_kategori/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /surat/{docId} {
      allow read: if isSignedIn() && (isTenantMember(resource.data.tenantId) || request.auth.uid == resource.data.authUid);
      allow create: if isSignedIn();
      allow update, delete: if isPengurus() && isTenantMember(resource.data.tenantId);
    }


    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || (resource != null && "email" in resource.data && "email" in request.auth.token && resource.data.email == request.auth.token.email));
      allow create: if (isPengurus() && isTenantMember(request.resource.data.tenantId)) || isSignedIn() && request.auth.uid == userId; // allow users to create their own record
      allow update, delete: if isPengurus() && isTenantMember(request.resource.data.tenantId);
      allow list: if isPengurus();
      allow read, write: if isAdmin(); // Admin override
    }

    match /public_usernames/{username} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /verifikasi_warga/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /balita/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /sampah_setoran/{docId} {
      allow read, write: if isTenantMember(resource.data.tenantId);
    }

    match /warga/{docId} {
      allow read: if isSignedIn();
      allow write: if isTenantMember(request.resource.data.tenantId) || isTenantMember(resource.data.tenantId);
    }

    match /data_warga/{docId} {
      allow read: if isSignedIn();
      allow write: if isTenantMember(request.resource.data.tenantId) || isTenantMember(resource.data.tenantId);
    }

    match /voting_candidates/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /voting_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /voting_votes/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isPengurus();
      allow delete: if isPengurus();
    }

    match /toko_products/{docId} {
      allow read: if isSignedIn();
      allow write: if isPengurus();
    }

    match /toko_orders/{docId} {
      allow read: if isSignedIn() && (resource == null || resource.data.customerId == request.auth.uid || isPengurus());
      allow create: if isSignedIn();
      allow update: if isPengurus();
      allow delete: if isPengurus();
    }
  }
}
