rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return isSignedIn() 
        ? (exists(/databases/$(database)/documents/users/$(request.auth.uid))
           ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
           : (exists(/databases/$(database)/documents/data_warga/$(request.auth.uid))
              ? get(/databases/$(database)/documents/data_warga/$(request.auth.uid)).data
              : ('email' in request.auth.token
                 ? (exists(/databases/$(database)/documents/users/$(request.auth.token.email.lowerCase()))
                    ? get(/databases/$(database)/documents/users/$(request.auth.token.email.lowerCase())).data
                    : (exists(/databases/$(database)/documents/users/$(request.auth.token.email))
                       ? get(/databases/$(database)/documents/users/$(request.auth.token.email)).data
                       : (exists(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lowerCase()))
                          ? get(/databases/$(database)/documents/users/$("PRE_" + request.auth.token.email.lowerCase())).data
                          : null)))
                 : null)))
        : null;
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email.lowerCase() == 'arifrajcoach@gmail.com') || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && (
        isAdmin() ||
        (tenantId != null && getUserData() != null && 'tenantId' in getUserData() && getUserData().tenantId != null && (
          getUserData().tenantId.lowerCase() == tenantId.lowerCase() || 
          getUserData().tenantId == 'MASTER' || 
          (getUserData().tenantId.lowerCase() == 'rw26_berjuang' && tenantId.lowerCase().matches('.*berjuang.*')) ||
          (getUserData().tenantId.lowerCase() == 'trihprw26' && tenantId.lowerCase().matches('.*trih.*')) ||
          getUserData().tenantId.lowerCase().matches('.*_' + tenantId.lowerCase()) ||
          tenantId.lowerCase().matches('.*_' + getUserData().tenantId.lowerCase()) ||
          ((getUserData().tenantId.lowerCase().matches('.*rw26.*') || getUserData().tenantId.lowerCase().matches('.*berjuang.*')) && 
           (tenantId.lowerCase().matches('.*rw26.*') || tenantId.lowerCase().matches('.*berjuang.*')) && (
             (getUserData().tenantId.lowerCase().matches('.*rt0?1.*') && tenantId.lowerCase().matches('.*rt0?1.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?2.*') && tenantId.lowerCase().matches('.*rt0?2.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?3.*') && tenantId.lowerCase().matches('.*rt0?3.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?4.*') && tenantId.lowerCase().matches('.*rt0?4.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?5.*') && tenantId.lowerCase().matches('.*rt0?5.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?6.*') && tenantId.lowerCase().matches('.*rt0?6.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?7.*') && tenantId.lowerCase().matches('.*rt0?7.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?8.*') && tenantId.lowerCase().matches('.*rt0?8.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?9.*') && tenantId.lowerCase().matches('.*rt0?9.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?10.*') && tenantId.lowerCase().matches('.*rt0?10.*'))
          )) ||
          (getUserData().tenantId.lowerCase().matches('.*trih.*') && tenantId.lowerCase().matches('.*trih.*') && (
             (getUserData().tenantId.lowerCase().matches('.*rt0?1.*') && tenantId.lowerCase().matches('.*rt0?1.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?2.*') && tenantId.lowerCase().matches('.*rt0?2.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?3.*') && tenantId.lowerCase().matches('.*rt0?3.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?4.*') && tenantId.lowerCase().matches('.*rt0?4.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?5.*') && tenantId.lowerCase().matches('.*rt0?5.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?6.*') && tenantId.lowerCase().matches('.*rt0?6.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?7.*') && tenantId.lowerCase().matches('.*rt0?7.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?8.*') && tenantId.lowerCase().matches('.*rt0?8.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?9.*') && tenantId.lowerCase().matches('.*rt0?9.*')) ||
             (getUserData().tenantId.lowerCase().matches('.*rt0?10.*') && tenantId.lowerCase().matches('.*rt0?10.*'))
          ))
        )) ||
        (tenantId != null && 'email' in request.auth.token && request.auth.token.email.lowerCase() == tenantId.lowerCase() + "@gmail.com") ||
        (tenantId != null && 'email' in request.auth.token && (
            (request.auth.token.email.lowerCase().matches('^rt0?1.*') && tenantId.lowerCase().matches('.*rt0?1.*')) ||
            (request.auth.token.email.lowerCase().matches('^rt0?2.*') && tenantId.lowerCase().matches('.*rt0?2.*')) ||
            (request.auth.token.email.lowerCase().matches('^rt0?3.*') && tenantId.lowerCase().matches('.*rt0?3.*')) ||
            (request.auth.token.email.lowerCase().matches('^rt0?4.*') && tenantId.lowerCase().matches('.*rt0?4.*')) ||
            (request.auth.token.email.lowerCase().matches('^rt0?5.*') && tenantId.lowerCase().matches('.*rt0?5.*')) ||
            (request.auth.token.email.lowerCase().matches('^rt0?6.*') && tenantId.lowerCase().matches('.*rt0?6.*')) ||
            (request.auth.token.email.lowerCase().matches('^rt0?7.*') && tenantId.lowerCase().matches('.*rt0?7.*')) ||
            (request.auth.token.email.lowerCase().matches('^rt0?8.*') && tenantId.lowerCase().matches('.*rt0?8.*')) ||
            (request.auth.token.email.lowerCase().matches('^rt0?9.*') && tenantId.lowerCase().matches('.*rt0?9.*')) ||
            (request.auth.token.email.lowerCase().matches('^rt10.*') && tenantId.lowerCase().matches('.*rt10.*')) ||
            (request.auth.token.email.lowerCase().matches('^rw26.*') && tenantId.lowerCase().matches('.*rw26.*'))
        ))
      );
    }

    function isPengurus() {
      return isSignedIn() && (
        (getUserData() != null && (
          ('role' in getUserData() && getUserData().role in ['RT', 'RW', 'BENDAHARA', 'SEKRETARIS', 'KADER', 'KETUA RT', 'KETUA RW', 'PENGURUS', 'SUPER_ADMIN', 'ADMIN', 'rt', 'rw', 'bendahara', 'sekretaris', 'kader', 'ketua rt', 'ketua rw', 'pengurus', 'super_admin', 'admin']) ||
          ('role' in getUserData() && getUserData().role is string && getUserData().role.lowerCase().matches('.*(rt|rw|bendahara|sekretaris|kader|admin|pengurus|super_admin).*')) ||
          ('tenantId' in getUserData() && getUserData().tenantId == 'MASTER')
        )) ||
        ('email' in request.auth.token && (
          request.auth.token.email.lowerCase().matches('.*rt.*') || 
          request.auth.token.email.lowerCase().matches('.*rw.*') ||
          request.auth.token.email.lowerCase().matches('.*admin.*')
        ))
      );
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        (isPengurus() && exists(/databases/$(database)/documents/users/$(userId)) && isTenantMember(get(/databases/$(database)/documents/users/$(userId)).data.tenantId))
      );
      allow delete: if isAdmin();
    }

    match /tenants/{tenantId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isAdmin() || (isPengurus() && isTenantMember(tenantId));
    }

    match /data_warga/{nik} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isAdmin() ||
        isPengurus() ||
        ((resource == null || ('tenantId' in resource.data && isTenantMember(resource.data.tenantId))) && 
         (request.resource == null || ('tenantId' in request.resource.data && isTenantMember(request.resource.data.tenantId))))
      );
    }

    match /verifikasi_warga/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isPengurus() || isAdmin());
      allow delete: if isAdmin();
    }

    match /surat/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (
        isSignedIn() && (
          resource.data.authUid == request.auth.uid || 
          resource.data.userId == request.auth.uid || 
          (getUserData() != null && 'nik' in getUserData() && resource.data.nik == getUserData().nik) ||
          (isPengurus() && 'tenantId' in resource.data && isTenantMember(resource.data.tenantId))
        )
      );
      allow delete: if isAdmin() || (
        isSignedIn() && (
          resource.data.authUid == request.auth.uid || 
          resource.data.userId == request.auth.uid || 
          (getUserData() != null && 'nik' in getUserData() && resource.data.nik == getUserData().nik) ||
          (isPengurus() && 'tenantId' in resource.data && isTenantMember(resource.data.tenantId))
        )
      );
    }

    match /kas/{id} {
      allow read: if isSignedIn();
      allow write: if isPengurus() && ('tenantId' in request.resource.data) && isTenantMember(request.resource.data.tenantId);
    }

    match /iuran/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if (isPengurus() && 'tenantId' in resource.data && isTenantMember(resource.data.tenantId)) || (
        isSignedIn() && resource != null && (
          resource.data.get('userId', '') == request.auth.uid ||
          resource.data.get('recordedBy', '') == request.auth.uid ||
          (getUserData() != null && 'nik' in getUserData() && resource.data.get('nik', '') == getUserData().nik) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('nik', '') == resource.data.get('nik', '')) ||
          (exists(/databases/$(database)/documents/data_warga/$(request.auth.uid)) && get(/databases/$(database)/documents/data_warga/$(request.auth.uid)).data.get('nik', '') == resource.data.get('nik', ''))
        )
      );
    }

    match /branding/{tenantId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /toko_products/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /chat_messages/{id} {
      allow read: if isSignedIn();
      allow create: if ('tenantId' in request.resource.data) && isTenantMember(request.resource.data.tenantId);
    }

    match /complaints/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if (isPengurus() && ('tenantId' in resource.data) && isTenantMember(resource.data.tenantId)) || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
    }

    match /emergencies/{id} {
      allow read, write: if isSignedIn();
    }

    match /emergency_logs/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.get('userId', '') == request.auth.uid;
      allow write: if isAdmin();
    }

    match /subscriptions/{tenantId} {
      allow read, write: if isSignedIn();
    }

    match /push_subscriptions/{subId} {
      allow read, write: if true;
    }

    match /mading/{id} {
      allow read: if true;
      allow write: if isPengurus();
    }
    
    match /settings/{docId} {
      allow read, write: if true;
    }

    match /tenant_settings/{tenantId} {
      allow read, write: if isSignedIn();
    }

    // Catch-all
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
