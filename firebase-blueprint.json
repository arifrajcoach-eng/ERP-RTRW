{
  "entities": {
    "Warga": {
      "title": "Warga",
      "description": "Data kependudukan warga RT/RW",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string", "description": "ID Penyewa (Multi-tenancy)" },
        "nik": { "type": "string", "description": "Nomor Induk Kependudukan (Unique ID)" },
        "kk": { "type": "string" },
        "nama": { "type": "string" },
        "rt": { "type": "string" },
        "rw": { "type": "string" },
        "blok": { "type": "string" },
        "kelurahan": { "type": "string" },
        "kecamatan": { "type": "string" },
        "kota_kab": { "type": "string" },
        "status": { "type": "string" },
        "hp": { "type": "string" },
        "email": { "type": "string", "description": "Alamat Email Warga" },
        "foto": { "type": "string", "description": "URL Foto Profil Warga" },
        "posisi": { "type": "string" },
        "profesi": { "type": "string" },
        "jk": { "type": "string" },
        "tglLahir": { "type": "string", "format": "date" },
        "tglDaftar": { "type": "string", "format": "date" }
      },
      "required": ["nik", "nama", "tenantId"]
    },
    "Kas": {
      "title": "Kas",
      "description": "Catatan keuangan kas lingkungan",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "tanggal": { "type": "string" },
        "tipe": { "type": "string", "enum": ["Masuk", "Keluar"] },
        "transaksi": { "type": "string" },
        "nama": { "type": "string" },
        "keterangan": { "type": "string" },
        "debit": { "type": "number" },
        "kredit": { "type": "number" }
      },
      "required": ["id", "tanggal", "tipe", "tenantId"]
    },
    "Surat": {
      "title": "Surat",
      "description": "Permohonan surat pengantar dengan identitas lengkap",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "rt": { "type": "string" },
        "tanggal": { "type": "string" },
        "pemohon": { "type": "string" },
        "nik": { "type": "string" },
        "ttl": { "type": "string" },
        "jk": { "type": "string" },
        "agama": { "type": "string" },
        "pekerjaan": { "type": "string" },
        "statusKawin": { "type": "string" },
        "alamat": { "type": "string" },
        "rt_rw": { "type": "string" },
        "kelurahan": { "type": "string" },
        "kecamatan": { "type": "string" },
        "kota_kab": { "type": "string" },
        "kewarganegaraan": { "type": "string" },
        "pendidikan": { "type": "string" },
        "kk": { "type": "string" },
        "keperluan": { "type": "string" },
        "jenis": { "type": "string" },
        "status": { "type": "string", "enum": ["Diajukan", "Selesai", "Ditolak"] }
      },
      "required": ["id", "pemohon", "status", "nik", "jenis", "tenantId"]
    },
    "Iuran": {
      "title": "Iuran",
      "description": "Catatan iuran bulanan warga",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "rt": { "type": "string" },
        "tanggal": { "type": "string" },
        "transaksi": { "type": "string" },
        "nama": { "type": "string" },
        "periode": { "type": "string" },
        "nominal": { "type": "number" },
        "status": { "type": "string", "enum": ["Lunas", "Pending"] },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "nama", "nominal", "status", "tenantId"]
    },
    "User": {
      "title": "User",
      "description": "User profiles and roles with unit mapping",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Operator", "Viewer"] },
        "isSuperAdmin": { "type": "boolean" },
        "unitMapping": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of RT/Units this user can manage (for Operators)"
        },
        "nikMapping": { 
          "type": "string", 
          "description": "Linked NIK for residents (for Viewers)"
        }
      },
      "required": ["email", "role", "tenantId"]
    },
    "Balita": {
      "title": "Balita",
      "description": "Data anak balita untuk pemantauan Posyandu",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "tglLahir": { "type": "string", "format": "date" },
        "jk": { "type": "string", "enum": ["Laki-Laki", "Perempuan"] },
        "orangTuaId": { "type": "string", "description": "NIK Orang Tua (relasi ke Warga)" },
        "namaOrangTua": { "type": "string" },
        "alamat": { "type": "string" },
        "rt": { "type": "string" },
        "rw": { "type": "string" },
        "statusStunting": { "type": "string", "enum": ["Normal", "Risiko Stunting", "Stunting"] }
      },
      "required": ["id", "nama", "tglLahir", "jk", "orangTuaId", "tenantId"]
    },
    "IbuHamil": {
      "title": "Ibu Hamil",
      "description": "Data ibu hamil di lingkungan",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "nik": { "type": "string" },
        "nama": { "type": "string" },
        "tglHPL": { "type": "string", "format": "date" },
        "usiaKehamilan": { "type": "number", "description": "Minggu" },
        "riwayatKesehatan": { "type": "string" },
        "rt": { "type": "string" },
        "rw": { "type": "string" }
      },
      "required": ["id", "nama", "nik", "tenantId"]
    },
    "PosyanduKegiatan": {
      "title": "Kegiatan Posyandu",
      "description": "Jadwal dan catatan kegiatan posyandu bulanan",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "tanggal": { "type": "string", "format": "date" },
        "lokasi": { "type": "string" },
        "kaderId": { "type": "string" },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "tanggal", "lokasi", "tenantId"]
    },
    "PemeriksaanBalita": {
      "title": "Pemeriksaan Balita",
      "description": "Catatan hasil pemeriksaan rutin balita",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "balitaId": { "type": "string" },
        "kegiatanId": { "type": "string" },
        "tanggal": { "type": "string", "format": "date" },
        "beratBadan": { "type": "number", "description": "kg" },
        "tinggiBadan": { "type": "number", "description": "cm" },
        "lingkarKepala": { "type": "number", "description": "cm" },
        "statusGizi": { "type": "string" },
        "catatan": { "type": "string" }
      },
      "required": ["id", "balitaId", "tanggal", "tenantId"]
    },
    "Imunisasi": {
      "title": "Imunisasi",
      "description": "Catatan imunisasi balita",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "balitaId": { "type": "string" },
        "jenisImunisasi": { "type": "string" },
        "tanggal": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Selesai", "Terjadwal"] }
      },
      "required": ["id", "balitaId", "jenisImunisasi", "tanggal", "tenantId"]
    },
    "SampahKategori": {
      "title": "Kategori Sampah",
      "description": "Jenis sampah yang dapat ditabung (Plastik, Kertas, Logam, dll)",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "satuan": { "type": "string", "enum": ["kg", "liter", "pcs"] },
        "hargaBeli": { "type": "number", "description": "Harga beli dari warga" }
      },
      "required": ["id", "nama", "satuan", "hargaBeli", "tenantId"]
    },
    "SampahSetoran": {
      "title": "Setoran Sampah",
      "description": "Transaksi warga menabung sampah",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "nasabahId": { "type": "string", "description": "NIK Warga" },
        "namaNasabah": { "type": "string" },
        "kategoriId": { "type": "string" },
        "namaKategori": { "type": "string" },
        "berat": { "type": "number" },
        "harga": { "type": "number" },
        "total": { "type": "number" },
        "tanggal": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Menunggu", "Selesai"] },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "nasabahId", "kategoriId", "berat", "total", "tanggal", "tenantId"]
    },
    "SampahTarikSaldo": {
      "title": "Tarik Saldo Sampah",
      "description": "Transaksi warga menarik uang hasil tabungan sampah",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "nasabahId": { "type": "string" },
        "namaNasabah": { "type": "string" },
        "nominal": { "type": "number" },
        "tanggal": { "type": "string", "format": "date" },
        "keterangan": { "type": "string" }
      },
      "required": ["id", "nasabahId", "nominal", "tanggal", "tenantId"]
    },
    "Emergency": {
      "title": "Sinyal Darurat (SOS)",
      "description": "Sinyal darurat aktif dari warga untuk bantuan segera",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userLocation": { "type": "string", "description": "Blok/Unit atau Koordinat" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ACTIVE", "RESOLVED"] },
        "resolvedBy": { "type": "string" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userName", "status", "tenantId"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "Tenant (RT/RW) configuration and subscription info",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "adminEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Trial"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "status"]
    },
    "Branding": {
      "title": "Branding",
      "description": "Branding settings per RT/RW (Multi-tenant)",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "nama_rt": { "type": "string" },
        "alamat": { "type": "string" },
        "wilayah": { "type": "string" },
        "telepon": { "type": "string" },
        "logo_url": { "type": "string" },
        "warna_primary": { "type": "string" },
        "warna_secondary": { "type": "string" },
        "ttd_url": { "type": "string" },
        "stempel_url": { "type": "string" },
        "nama_ketua": { "type": "string" },
        "kelurahan": { "type": "string" },
        "kecamatan": { "type": "string" },
        "kabupaten": { "type": "string" }
      },
      "required": ["id", "tenantId"]
    },
    "Template": {
      "title": "Template",
      "description": "Document templates per RT/RW (Multi-tenant)",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["surat_pengantar", "kwitansi", "laporan_keuangan"] },
        "template_html": { "type": "string" },
        "is_default": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tenantId", "type", "template_html"]
    },
    "VerifikasiWarga": {
      "title": "Verifikasi Warga",
      "description": "Permohonan verifikasi atau perbaikan data mandiri oleh warga",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "nik": { "type": "string" },
        "nama": { "type": "string" },
        "kk": { "type": "string" },
        "alamat": { "type": "string" },
        "hp": { "type": "string" },
        "pekerjaan": { "type": "string" },
        "pendidikan": { "type": "string" },
        "statusKawin": { "type": "string" },
        "anggotaKeluarga": { "type": "string" },
        "ktpUrl": { "type": "string" },
        "kkUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Belum Diverifikasi", "Menunggu Persetujuan", "Disetujui", "Ditolak"] },
        "catatan": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "approvedBy": { "type": "string" }
      },
      "required": ["id", "nik", "nama", "tenantId", "status"]
    },
    "BukuTamu": {
      "title": "Buku Tamu Digital",
      "description": "Catatan tamu atau pengunjung lingkungan",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "alamat": { "type": "string" },
        "noHp": { "type": "string" },
        "tujuan": { "type": "string", "description": "Blok/No Rumah yang dituju" },
        "keperluan": { "type": "string" },
        "fotoUrl": { "type": "string", "description": "Foto wajah/identitas tamu" },
        "waktuDatang": { "type": "string", "format": "date-time" },
        "waktuKeluar": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Bertamu", "Selesai"] }
      },
      "required": ["id", "nama", "tujuan", "waktuDatang", "tenantId", "status"]
    }
  },
  "firestore": {
    "/buku_tamu/{id}": {
      "schema": "BukuTamu",
      "description": "Koleksi catatan tamu digital"
    },
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Koleksi data penyewa (RT/RW)"
    },
    "/branding/{tenantId}": {
      "schema": "Branding",
      "description": "Pengaturan branding per tenant"
    },
    "/templates/{id}": {
      "schema": "Template",
      "description": "Template dokumen per tenant"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Koleksi profil pengguna dan peran"
    },
    "/warga/{nik}": {
      "schema": "Warga",
      "description": "Koleksi data warga"
    },
    "/verifikasi_warga/{id}": {
      "schema": "VerifikasiWarga",
      "description": "Koleksi permohonan verifikasi data warga mandiri"
    },
    "/kas/{id}": {
      "schema": "Kas",
      "description": "Koleksi mutasi kas"
    },
    "/surat/{id}": {
      "schema": "Surat",
      "description": "Koleksi permohonan surat"
    },
    "/iuran/{id}": {
      "schema": "Iuran",
      "description": "Koleksi catatan iuran"
    },
    "/balita/{id}": {
      "schema": "Balita",
      "description": "Koleksi data balita"
    },
    "/ibu_hamil/{id}": {
      "schema": "IbuHamil",
      "description": "Koleksi data ibu hamil"
    },
    "/posyandu_kegiatan/{id}": {
      "schema": "PosyanduKegiatan",
      "description": "Koleksi kegiatan posyandu"
    },
    "/pemeriksaan_balita/{id}": {
      "schema": "PemeriksaanBalita",
      "description": "Koleksi hasil pemeriksaan balita"
    },
    "/imunisasi/{id}": {
      "schema": "Imunisasi",
      "description": "Koleksi riwayat imunisasi"
    },
    "/sampah_kategori/{id}": {
      "schema": "SampahKategori",
      "description": "Data kategori sampah"
    },
    "/sampah_setoran/{id}": {
      "schema": "SampahSetoran",
      "description": "Transaksi setoran sampah"
    },
    "/sampah_tarik_saldo/{id}": {
      "schema": "SampahTarikSaldo",
      "description": "Transaksi tarik saldo sampah"
    },
    "/emergencies/{id}": {
      "schema": "Emergency",
      "description": "Koleksi sinyal darurat aktif"
    }
  }
}
